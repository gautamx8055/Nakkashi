---
const base = import.meta.env.BASE_URL;
const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || (href !== '/' && pathname.startsWith(href));

const links = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/#partners', label: 'Execution Partners' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header" id="header">
  <div class="wrap">
    <nav class="primary">
      <a href="/" class="brand">
        <img src={`${base}Nakashi-logo-final-Transparent.png`} alt="Nakkashi Signature Painting" />
      </a>

      <form class="nav-search" role="search" id="navSearch" autocomplete="off">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m20 20-3.5-3.5"/>
        </svg>
        <input type="search" name="q" placeholder='Find what you are looking for ?' aria-label="Search" />
      </form>

      <ul class="navlinks" id="navlinks">
        {links.map(l => (
          <li><a href={l.href} class:list={{ active: isActive(l.href) }}>{l.label}</a></li>
        ))}
      </ul>

      <div class="nav-cta">
        <a href="/quote" class="btn btn-gold">
          Get a Quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    const ham = document.getElementById('hamburger');
    const nl = document.getElementById('navlinks');
    if (ham && nl) {
      ham.addEventListener('click', () => nl.classList.toggle('open'));
      nl.querySelectorAll('a').forEach(a =>
        a.addEventListener('click', () => nl.classList.remove('open'))
      );
    }
    const hd = document.getElementById('header');
    if (hd) {
      const onScroll = () => hd.classList.toggle('scrolled', window.scrollY > 20);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    const sf = document.getElementById('navSearch');
    if (sf) {
      sf.addEventListener('submit', (e) => {
        e.preventDefault();
        const v = sf.querySelector('input').value.trim().toLowerCase();
        if (!v) return;
        const map = [
          { kw: ['texture','royale','stucco','art'], to: '/services#texture' },
          { kw: ['interior','emulsion','paint'], to: '/services#interior' },
          { kw: ['waterproof','seepage','leak'], to: '/services#waterproof' },
          { kw: ['statement','feature','mural','accent'], to: '/services#statement' },
          { kw: ['design','consult','consultation','consultancy'], to: '/services#consultancy' },
          { kw: ['surface','luxury','venetian','marble'], to: '/services#artistry' },
          { kw: ['partner','contractor','asian','berger','dulux','birla','sirca'], to: '/partners' },
          { kw: ['gallery','project','work'], to: '/gallery' },
          { kw: ['about','story','founder'], to: '/about' },
          { kw: ['quote','price','cost','estimate'], to: '/quote' },
          { kw: ['contact','call','reach'], to: '/contact' },
        ];
        const hit = map.find(m => m.kw.some(k => v.includes(k)));
        window.location.href = hit ? hit.to : '/services';
      });
    }
  })();
</script>
