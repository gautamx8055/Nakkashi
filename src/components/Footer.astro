---
import { withBase } from '../lib/url';
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---
<footer class="site-footer">
  <div class="wrap">
    <div class="foot-grid">
      <div class="foot-brand">
        <img src={withBase('/Nakashi-logo-final-Transparent.png')} alt="Nakkashi" />
        <p>
          Premium painting &amp; texture execution partner — transforming walls
          into signature spaces through master craftsmanship, premium materials,
          and professional execution.
        </p>
        <div class="foot-soc">
          <a href="https://wa.me/917400640093" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24"><path d="M20.5 3.5A11 11 0 003.6 17.3L2 22l4.8-1.6A11 11 0 1020.5 3.5z"/><path d="M8.3 8.1c.4-.7 1.1-.7 1.6-.7.5 0 .9 0 1.3.9.3.8.9 2 1 2.2.1.2.1.4 0 .7-.2.3-.3.5-.5.7-.2.2-.5.5-.2 1 .3.5 1.2 2 2.6 2.7 1.7.9 2.1.7 2.4.6.3-.1 1-.7 1.3-1 .3-.3.6-.3.9-.2.3.1 2 1 2.4 1.2.4.2.6.3.7.5.1.2.1 1-.3 1.9-.4.9-2.1 1.7-2.9 1.8-.7 0-1.5.3-5.2-1.1-4.4-1.7-7.1-6.2-7.3-6.4-.2-.3-1.7-2.2-1.7-4.2 0-2 1.1-3 1.5-3.4z"/></svg>
          </a>
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24">
              <rect x="2" y="2" width="20" height="20" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
            </svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z" />
              <rect x="2" y="9" width="4" height="12" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        </div>
      </div>

      <div class="foot-col">
        <h4>Services</h4>
        <a href={withBase('/services')}>Signature Texture Collection</a>
        <a href={withBase('/services')}>Elite Interior Finishes</a>
        <a href={withBase('/services')}>Luxury Surface Artistry</a>
        <a href={withBase('/services')}>Statement Wall Creations</a>
        <a href={withBase('/services')}>ShieldPro Waterproofing</a>
        <a href={withBase('/services')}>Design Consultancy</a>
      </div>

      <div class="foot-col">
        <h4>Company</h4>
        <a href={withBase('/about')}>About Nakkashi</a>
        <a href={withBase('/services')}>Services & Process</a>
        <a href={withBase('/gallery')}>Project Gallery</a>
        <a href={withBase('/quote')}>Request a Quote</a>
        <a href={withBase('/contact')}>Contact Us</a>
      </div>

      <div class="foot-col foot-contact">
        <h4>Get in Touch</h4>
        <div class="row">
          <svg viewBox="0 0 24 24">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>Connaught Place,<br />New Delhi, India</span>
        </div>
        <div class="row">
          <svg viewBox="0 0 24 24">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z" />
          </svg>
          <span><a href="tel:+917400640093">+91 74006 40093</a></span>
        </div>
        <div class="row">
          <svg viewBox="0 0 24 24" style="stroke:var(--gold)">
            <path d="M20.5 3.5A11 11 0 003.6 17.3L2 22l4.8-1.6A11 11 0 1020.5 3.5z"/>
            <path d="M8.3 8.1c.4-.7 1.1-.7 1.6-.7.5 0 .9 0 1.3.9.3.8.9 2 1 2.2.1.2.1.4 0 .7-.2.3-.3.5-.5.7-.2.2-.5.5-.2 1 .3.5 1.2 2 2.6 2.7 1.7.9 2.1.7 2.4.6.3-.1 1-.7 1.3-1 .3-.3.6-.3.9-.2.3.1 2 1 2.4 1.2.4.2.6.3.7.5.1.2.1 1-.3 1.9-.4.9-2.1 1.7-2.9 1.8-.7 0-1.5.3-5.2-1.1-4.4-1.7-7.1-6.2-7.3-6.4-.2-.3-1.7-2.2-1.7-4.2 0-2 1.1-3 1.5-3.4z"/>
          </svg>
          <span><a href="https://wa.me/917400640093" target="_blank" rel="noopener" style="color:var(--gold-soft)">+91 74006 40093</a></span>
        </div>
        <div class="row">
          <svg viewBox="0 0 24 24">
            <path d="M4 4h16v16H4z" /><path d="m22 6-10 7L2 6" />
          </svg>
          <span><a href="mailto:nakkashipainting@gmail.com">nakkashipainting@gmail.com</a></span>
        </div>
      </div>
    </div>

    <div class="foot-bottom">
      <div>© {year} Nakkashi Signature Painting. All rights reserved.</div>
      <div style="display:flex;gap:1.5rem">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
