---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import { withBase } from '../lib/url';

const principles = [
  { letter: 'N', name: 'Novel Thinking', desc: 'Fresh ideas and creative solutions to transform every space.' },
  { letter: 'A', name: 'Artistic Craftsmanship', desc: 'Creativity and precision that leaves a lasting impression.' },
  { letter: 'K', name: 'Knowledge-Driven Execution', desc: 'Expertise guiding every project to superior outcomes.' },
  { letter: 'K', name: 'Keen Attention to Detail', desc: 'Every detail from surface prep to final finish is perfected.' },
  { letter: 'A', name: 'Absolute Accountability', desc: 'Complete ownership of commitments, delivered professionally.' },
  { letter: 'S', name: 'Superior Quality', desc: 'Uncompromising standards in materials and workmanship.' },
  { letter: 'H', name: 'Honest Commitments', desc: 'Trust built through transparency and clear communication.' },
  { letter: 'I', name: 'Innovative Solutions', desc: "Customised textures tailored to every client's vision." },
];
---
<Layout title="About Nakkashi   Premium Painting & Decorative Finishes">
  <PageHero
    eyebrow="About"
    title="Where creativity meets craftsmanship."
    lead="Nakkashi is a premium end-to-end execution partner brand redefining how India experiences walls and spaces   through signature textures, master craftsmanship, and uncompromising professionalism."
  />

  <!-- BRAND STORY -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="content-grid">
        <div class="reveal">
          <div class="eyebrow">Our Story</div>
          <h2>Walls are more than structure   they're <em>identity</em>.</h2>
          <p>
            We believe walls define the character and mood of a space. With a passion for design
            and a commitment to quality, Nakkashi is a premium end-to-end execution partner brand  
            delivering luxury textures, decorative finishes, and customised painting solutions
            using trusted products from Asian Paints, Berger, Dulux, Birla Opus, and Sirca across
            residential, commercial, and hospitality projects.
          </p>
        </div>
        <div class="image-card reveal">
          <img src={withBase('/About-Nakkashi.webp')} alt="Nakkashi craftsmanship at work" style="object-position: right top;"  loading="lazy" decoding="async" />
          <span class="overlay-tag">Turning ordinary walls into extraordinary experiences.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- VISION / MISSION / VALUES -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Vision &amp; Mission</div>
        <h2>Driven by purpose. <em>Powered by craft.</em></h2>
      </div>

      <div class="assure-grid">
        <div class="assure-card reveal">
          <div class="num">01</div>
          <div class="icon-circle">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
          </div>
          <h3>Our Vision</h3>
          <p>To become India's most trusted brand for premium decorative finishes   connecting homeowners, architects, and craftsmen through quality, innovation, and trust.</p>
        </div>
        <div class="assure-card reveal">
          <div class="num">02</div>
          <div class="icon-circle">
            <svg viewBox="0 0 24 24"><path d="M3 12l3-3 3 3 3-7 3 7 3-3 3 3"/><path d="M3 18h18"/></svg>
          </div>
          <h3>Our Mission</h3>
          <p>To transform spaces through innovative designs, superior craftsmanship, and professional execution   making premium-grade finishes accessible to every space that deserves to be remembered.</p>
        </div>
      </div>

      <div class="text-center" style="margin-top:3rem">
        <div class="eyebrow" style="color:var(--gold-deep);margin-bottom:1rem">Our Core Values</div>
        <div class="values-bar reveal">
          <span class="val">Quality</span>
          <span class="val">Innovation</span>
          <span class="val">Trust</span>
          <span class="val">Professionalism</span>
          <span class="val">Excellence</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FOUNDER'S VISION -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">From the Founder</div>
        <h2>A vision for a new <em>standard</em> in painting.</h2>
      </div>

      <div class="founder-block reveal">
        <div class="hero-glow"></div>
        <div class="mark">"</div>
        <blockquote>
          Nakkashi was created to bridge the gap between creative design and quality execution  
          bringing together innovation, craftsmanship, and professionalism under one trusted name.
          My goal is to build India's most respected decorative finishes brand, where quality,
          trust, and artistic excellence become the standard, not the exception.
        </blockquote>
        <div class="signature">
          <div class="av">SM</div>
          <div class="who">
            <div class="nm">Shubham Mehrishi</div>
            <div class="rl">Founder &amp; CEO, Nakkashi</div>
          </div>
        </div>

        <div class="founder-cred">
          <div class="fc-label">A background built inside India's biggest paint brands</div>
          <div class="fc-brands">
            <span class="fc-chip">Trained with <strong>Asian Paints</strong></span>
            <span class="fc-chip">Certified applicator, <strong>Birla Opus</strong></span>
            <span class="fc-chip">15+ years of hands-on execution</span>
          </div>
          <p class="fc-note">
            Before founding Nakkashi, Shubham spent over a decade inside the training and
            execution programs of India's leading paint manufacturers   learning premium
            application techniques directly from the people who make the products. Nakkashi
            was built to bring that professional-grade standard to every home and space.
          </p>
        </div>
      </div>

      <style>
        .founder-cred {
          margin-top: 2.2rem;
          padding-top: 1.8rem;
          border-top: 1px solid rgba(224, 170, 62, .3);
        }
        .fc-label {
          font-size: .72rem;
          letter-spacing: .22em;
          text-transform: uppercase;
          font-weight: 700;
          color: var(--gold-deep);
          margin-bottom: 1rem;
        }
        .fc-brands {
          display: flex;
          flex-wrap: wrap;
          gap: .5rem;
          margin-bottom: 1.1rem;
        }
        .fc-chip {
          display: inline-flex;
          align-items: center;
          font-size: .82rem;
          padding: .4rem .85rem;
          border-radius: 50px;
          background: rgba(224, 170, 62, .12);
          border: 1px solid rgba(224, 170, 62, .3);
          color: var(--navy-deep);
        }
        .fc-chip strong { margin-left: .35rem; color: var(--gold-deep); }
        .fc-note {
          font-size: .95rem;
          line-height: 1.65;
          color: var(--muted);
          max-width: 62ch;
          margin: 0;
        }
      </style>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">The N·A·K·K·A·S·H·I Principles</div>
        <h2>Eight letters. <em>One philosophy.</em></h2>
      </div>
      <div class="principles">
        {principles.map(p => (
          <div class="principle-card reveal">
            <div class="letter">{p.letter}</div>
            <h3>{p.name}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    heading="Want to see what Nakkashi can do for <em>your</em> space?"
    text="A complimentary site visit is the best place to start. We'll meet you, understand your vision, and share our recommendation   no obligation."
    primaryLabel="Book a Free Site Visit"
    primaryHref="/quote"
    secondaryLabel="Explore Services"
    secondaryHref="/services"
  />
</Layout>
