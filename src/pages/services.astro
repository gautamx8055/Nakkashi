---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';

const services = [
  {
    title: 'Signature Texture Collection',
    tag: 'Texture',
    desc: 'Artistic textures that bring depth, character, and sophistication — stucco, lime-wash, metallic, and exclusive Nakkashi-original patterns.',
    bullets: [
      'Royale-play & art-effect textures',
      'Stucco, travertino & limewash',
      'Custom motif & stencil patterns',
      'Metallic & pearl finishes',
    ],
    icon: `<path d="M4 20l5-5"/><path d="M14 4l6 6-9 9H5v-6z"/><path d="M11 7l6 6"/>`,
  },
  {
    title: 'Elite Interior Finishes',
    tag: 'Interior',
    desc: 'Premium smooth emulsion finishes for living spaces, bedrooms, and ceilings — low-odour, washable, and built to last.',
    bullets: [
      'Premium emulsion & enamel systems',
      'Low-VOC, washable finishes',
      'Designer colour matching',
      'Furniture & ceiling refinishing',
    ],
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>`,
  },
  {
    title: 'Luxury Surface Artistry',
    tag: 'Decorative',
    desc: 'Italian-inspired Venetian plaster, bespoke metallic effects, and polished concrete — surfaces that feel as good as they look.',
    bullets: [
      'Venetian plaster & marmorino',
      'Metallic glazes & gold leaf',
      'Polished concrete effects',
      'Hand-applied colour layering',
    ],
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 010 18"/><path d="M3 12h18"/>`,
  },
  {
    title: 'Statement Wall Creations',
    tag: 'Feature',
    desc: 'Bespoke feature walls designed to anchor a room — custom murals, 3D textured panels, and architectural accent walls.',
    bullets: [
      'Architectural feature walls',
      'Custom-designed murals',
      '3D textured panels',
      'Headboard & accent walls',
    ],
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
  },
  {
    title: 'ShieldPro Waterproofing',
    tag: 'Protection',
    desc: 'Terrace, bathroom, and crack-sealing solutions that stop seepage at the source and protect your structure for years.',
    bullets: [
      'Terrace & roof waterproofing',
      'Bathroom & wet-area sealing',
      'Crack-bridging coatings',
      'Exterior weather-shield systems',
    ],
    icon: `<path d="M12 2s7 6 7 11a7 7 0 01-14 0c0-5 7-11 7-11z"/>`,
  },
  {
    title: 'Design & Finish Consultancy',
    tag: 'Consultancy',
    desc: 'Free on-site visits and digital previews so you can see your palette on your walls before a single brush is lifted.',
    bullets: [
      'Free on-site colour consultation',
      'Digital palette previews',
      'Designer collaboration',
      'Material recommendations',
    ],
    icon: `<circle cx="13.5" cy="6.5" r="2.5"/><circle cx="6.5" cy="11.5" r="2.5"/><circle cx="17" cy="14" r="2.5"/><path d="M12 22a3 3 0 003-3c0-1.5-3-4-3-4"/>`,
  },
  {
    title: 'Bespoke Surface Innovations',
    tag: 'Custom',
    desc: "When the standard collection doesn't fit your vision, we engineer something new — R&D textures and bespoke formulations.",
    bullets: [
      'R&D for custom textures',
      'Architect-led collaborations',
      'Mock-up panel development',
      'Bespoke colour formulations',
    ],
    icon: `<path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/>`,
  },
];

const steps = [
  { n: '01', title: 'Consultation', desc: 'An in-depth conversation covering your vision, style, and what success looks like for the project.' },
  { n: '02', title: 'Site Assessment', desc: 'On-site visit with measurements, surface evaluation, and moisture testing. Always complimentary.' },
  { n: '03', title: 'Design &amp; Texture Selection', desc: 'Curated samples, on-wall mock-ups, and digital previews before a single brush is lifted.' },
  { n: '04', title: 'Proposal &amp; Planning', desc: 'A clear, itemised quotation with timelines, materials, and crew allocation.' },
  { n: '05', title: 'Surface Preparation', desc: 'Cleaning, sanding, repair, and priming — the unsexy work that makes the finish extraordinary.' },
  { n: '06', title: 'Professional Application', desc: 'Trained applicators using premium materials and proven techniques for every signature finish.' },
  { n: '07', title: 'Quality Inspection', desc: 'A senior-led walk-through. Anything flagged is fixed before you ever see it.' },
  { n: '08', title: 'Project Handover', desc: 'Clean handover, care guide, and a complimentary 6-month inspection.' },
];

const assurances = [
  {
    title: 'Transparent Pricing',
    desc: 'No hidden costs. Every line item documented and explained — complete clarity from quotation to completion.',
    icon: `<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M7 15h4"/>`,
  },
  {
    title: 'Premium Materials',
    desc: 'High-quality products and proven systems from trusted premium manufacturers — never generic substitutes.',
    icon: `<path d="M12 2l3 6 6 1-4.5 4 1 6L12 16l-5.5 3 1-6L3 9l6-1z"/>`,
  },
  {
    title: 'Skilled Craftsmanship',
    desc: 'Experienced applicators delivering precision and consistency — continuously trained on new techniques.',
    icon: `<path d="M4 20l5-5"/><path d="M14 4l6 6-9 9H5v-6z"/><path d="M11 7l6 6"/>`,
  },
  {
    title: 'On-Time Delivery',
    desc: 'Professional planning that respects your time — clear timelines, and we stick to them.',
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  },
];

const privileges = [
  { n: '01', title: 'Complimentary Site Visit', desc: 'Experts visit your site, assess the space, and recommend the most suitable textures — free of charge.' },
  { n: '02', title: 'Free Designer Consultation', desc: 'Professional guidance on colour palettes, textures, and feature walls to bring your vision to life.' },
  { n: '03', title: 'Priority Scheduling', desc: 'Preferred project scheduling, dedicated coordination, and clear communication throughout.' },
  { n: '04', title: '6-Month Free Inspection', desc: 'Our commitment continues — a complimentary inspection after 6 months to ensure lasting beauty.' },
];
---
<Layout title="Our Services — Nakkashi Signature Painting">
  <PageHero
    eyebrow="Services"
    title="A full spectrum of premium painting & finishing services."
    lead="From signature textures to ShieldPro waterproofing — every Nakkashi service is delivered with the same standard of craftsmanship, material quality, and project care."
  />

  <!-- SERVICES -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">Our Signature Services</div>
        <h2>Crafted for every space — <em>residential, commercial, hospitality.</em></h2>
      </div>

      <div style="display:grid;gap:1.5rem;grid-template-columns:1fr">
        {services.map((s, i) => (
          <div class="reveal" style={`background:#fff;border:1px solid var(--line);border-radius:24px;padding:clamp(2rem,3.5vw,3rem);display:grid;grid-template-columns:90px 1fr auto;gap:2rem;align-items:start;box-shadow:var(--shadow-sm)`}>
            <div class="icon" style="width:80px;height:80px;border-radius:18px;background:linear-gradient(135deg,var(--cream),#fff);border:1px solid var(--line)">
              <svg viewBox="0 0 24 24" set:html={s.icon} style="width:36px;height:36px;stroke:var(--navy-deep);fill:none;stroke-width:1.6"></svg>
            </div>
            <div>
              <div style="display:flex;gap:.8rem;align-items:center;margin-bottom:.5rem">
                <span style="font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:var(--gold-deep);background:rgba(224,170,62,.12);padding:.3rem .7rem;border-radius:50px">{s.tag}</span>
                <span style="font-family:var(--display);font-style:italic;color:var(--muted);font-size:.95rem">— 0{i + 1}</span>
              </div>
              <h3 style="font-family:var(--display);font-size:1.65rem;font-weight:500;color:var(--navy-deep);margin-bottom:.8rem">{s.title}</h3>
              <p style="color:var(--muted);font-size:1.02rem;margin-bottom:1.2rem">{s.desc}</p>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
                {s.bullets.map(b => (
                  <div style="display:flex;gap:.5rem;align-items:center;font-size:.92rem;color:var(--navy-deep)">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0"></span>
                    <span>{b}</span>
                  </div>
                ))}
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:.6rem;align-items:flex-end">
              <a href="/quote" class="btn btn-gold" style="font-size:.88rem;padding:.7rem 1.3rem">Request Quote</a>
              <a href="/contact" style="font-size:.85rem;color:var(--gold-deep);font-weight:600;text-decoration:none">Talk to an Expert →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 8-STEP PROCESS -->
  <section class="section bg-dark process-section">
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="sec-head center reveal" style="position:relative;z-index:2">
        <div class="eyebrow">Our Process</div>
        <h2>Eight steps. <em>One standard.</em></h2>
        <p>From first call to final walk-through — so you always know what's happening, when, and why.</p>
      </div>

      <div class="process-flow reveal">
        {steps.map((s, i) => (
          <div class="pf-step">
            <div class="pf-node">
              <span class="pf-num">{s.n}</span>
            </div>
            <h3 set:html={s.title}></h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="stat-strip">
        <div class="stat-item"><div class="num">24h</div><div class="lbl">Quote Turnaround</div></div>
        <div class="stat-item"><div class="num">100%</div><div class="lbl">Transparent Pricing</div></div>
        <div class="stat-item"><div class="num">6 mo</div><div class="lbl">Free Inspection</div></div>
        <div class="stat-item"><div class="num">15 yr</div><div class="lbl">Of Craft Expertise</div></div>
      </div>
    </div>
  </section>

  <style>
    .process-section .process-flow {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2.4rem 1.5rem;
      margin-top: 2.5rem;
    }
    .process-section .pf-step {
      position: relative;
      text-align: center;
      padding: 0 0.5rem;
    }
    /* horizontal connector between tiles in same row */
    .process-section .pf-step::after {
      content: '';
      position: absolute;
      top: 33px;
      left: calc(50% + 36px);
      right: calc(-50% + 36px);
      height: 1px;
      background: linear-gradient(90deg, rgba(224, 170, 62, 0.55), rgba(224, 170, 62, 0.1));
      pointer-events: none;
    }
    .process-section .pf-step:nth-child(4n)::after { display: none; }

    .process-section .pf-node {
      width: 66px;
      height: 66px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #F1C56F, #C8902A 75%);
      display: grid;
      place-items: center;
      margin: 0 auto 1.1rem;
      position: relative;
      z-index: 2;
      box-shadow:
        0 0 0 6px rgba(224, 170, 62, 0.12),
        0 12px 24px rgba(0, 0, 0, 0.35);
    }
    .process-section .pf-num {
      font-family: var(--display, 'Fraunces', serif);
      font-style: italic;
      font-weight: 600;
      font-size: 1.5rem;
      color: #022044;
      letter-spacing: 0.02em;
    }
    .process-section .pf-step h3 {
      font-family: var(--display, 'Fraunces', serif);
      font-size: 1.1rem;
      font-weight: 500;
      color: #fff;
      margin: 0 0 0.45rem;
      line-height: 1.2;
    }
    .process-section .pf-step p {
      font-size: 0.88rem;
      color: rgba(247, 243, 234, 0.72);
      line-height: 1.55;
      margin: 0;
      max-width: 28ch;
      margin-inline: auto;
    }

    @media (max-width: 960px) {
      .process-section .process-flow { grid-template-columns: repeat(2, 1fr); gap: 2.2rem 1.2rem; }
      .process-section .pf-step:nth-child(4n)::after { display: block; }
      .process-section .pf-step:nth-child(2n)::after { display: none; }
    }
    @media (max-width: 560px) {
      .process-section .process-flow { grid-template-columns: 1fr; gap: 1.6rem; }
      .process-section .pf-step::after { display: none !important; }
      .process-section .pf-step { display: grid; grid-template-columns: 66px 1fr; text-align: left; gap: 1.1rem; align-items: start; }
      .process-section .pf-node { margin: 0; }
      .process-section .pf-step p { margin-inline: 0; max-width: none; }
    }
  </style>

  <!-- THE NAKKASHI ASSURANCE -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">The Nakkashi Assurance</div>
        <h2>Four pillars that define <em>every</em> Nakkashi project.</h2>
      </div>

      <div class="assure-grid">
        {assurances.map((a, i) => (
          <div class="assure-card reveal">
            <div class="num">{String(i + 1).padStart(2, '0')}</div>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" set:html={a.icon}></svg>
            </div>
            <h3>{a.title}</h3>
            <p>{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUSTOMER PRIVILEGES -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">Customer Privileges</div>
        <h2>Complimentary benefits — for every client.</h2>
      </div>

      <div class="assure-grid">
        {privileges.map(p => (
          <div class="assure-card reveal" style="background:linear-gradient(160deg,#fff,var(--cream))">
            <div class="num">{p.n}</div>
            <div class="icon-circle" style="background:linear-gradient(135deg,var(--navy-deep),var(--navy-700))">
              <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    heading="Tell us about your space — get a <em>tailored</em> quotation."
    text="Every Nakkashi project starts with understanding your vision. Send us your details and we'll respond within 24 hours."
    primaryLabel="Start Your Project"
    primaryHref="/quote"
    secondaryLabel="Talk to Us"
    secondaryHref="/contact"
  />
</Layout>
