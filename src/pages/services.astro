---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';

const services = [
  {
    title: 'Signature Texture Collection',
    tag: 'Texture',
    desc: 'Artistic textures designed to bring depth, character, and sophistication to every surface. Our curated collection includes stucco, lime-wash, metallic textures, and exclusive Nakkashi-original patterns.',
    bullets: [
      'Royale-play & art-effect textures',
      'Stucco, travertino & limewash',
      'Custom motif & stencil patterns',
      'Metallic & pearl finishes',
    ],
    icon: `<path d="M4 20l5-5"/><path d="M14 4l6 6-9 9H5v-6z"/><path d="M11 7l6 6"/>`,
  },
  {
    title: 'Elite Interior Finishes',
    tag: 'Interior',
    desc: 'Premium painting solutions crafted to deliver flawless aesthetics and enduring beauty. Smooth, premium emulsion finishes for living spaces, bedrooms, and ceilings — low-odour, washable, and built to last.',
    bullets: [
      'Premium emulsion & enamel systems',
      'Low-VOC, washable finishes',
      'Designer colour matching',
      'Furniture & ceiling refinishing',
    ],
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>`,
  },
  {
    title: 'Luxury Surface Artistry',
    tag: 'Decorative',
    desc: 'Exclusive decorative finishes inspired by contemporary architecture and luxury interiors. From Italian-inspired Venetian plaster to bespoke metallic effects, we create surfaces that feel as good as they look.',
    bullets: [
      'Venetian plaster & marmorino',
      'Metallic glazes & gold leaf',
      'Polished concrete effects',
      'Hand-applied colour layering',
    ],
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 010 18"/><path d="M3 12h18"/>`,
  },
  {
    title: 'Statement Wall Creations',
    tag: 'Feature',
    desc: 'Bespoke feature walls designed to become the focal point of exceptional spaces. We collaborate with you and your designer to create one-of-a-kind walls that anchor a room.',
    bullets: [
      'Architectural feature walls',
      'Custom-designed murals',
      '3D textured panels',
      'Headboard & accent walls',
    ],
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
  },
  {
    title: 'ShieldPro Waterproofing',
    tag: 'Protection',
    desc: 'Advanced protection systems engineered to safeguard structures from moisture and seepage. Terrace, bathroom, and crack-sealing solutions that stop seepage at the source and protect your structure for years.',
    bullets: [
      'Terrace & roof waterproofing',
      'Bathroom & wet-area sealing',
      'Crack-bridging coatings',
      'Exterior weather-shield systems',
    ],
    icon: `<path d="M12 2s7 6 7 11a7 7 0 01-14 0c0-5 7-11 7-11z"/>`,
  },
  {
    title: 'Design & Finish Consultancy',
    tag: 'Consultancy',
    desc: 'Expert guidance in selecting textures, finishes, and colour palettes that align with your vision. Free on-site visits and digital previews so you can see your palette on your walls before a single brush is lifted.',
    bullets: [
      'Free on-site colour consultation',
      'Digital palette previews',
      'Designer collaboration',
      'Material recommendations',
    ],
    icon: `<circle cx="13.5" cy="6.5" r="2.5"/><circle cx="6.5" cy="11.5" r="2.5"/><circle cx="17" cy="14" r="2.5"/><path d="M12 22a3 3 0 003-3c0-1.5-3-4-3-4"/>`,
  },
  {
    title: 'Bespoke Surface Innovations',
    tag: 'Custom',
    desc: 'Tailor-made texture concepts and customised finishes developed for unique design requirements. When the standard collection doesn’t fit your vision, we engineer something new.',
    bullets: [
      'R&D for custom textures',
      'Architect-led collaborations',
      'Mock-up panel development',
      'Bespoke colour formulations',
    ],
    icon: `<path d="M12 2v4"/><path d="M12 18v4"/><path d="M4.93 4.93l2.83 2.83"/><path d="M16.24 16.24l2.83 2.83"/><path d="M2 12h4"/><path d="M18 12h4"/><path d="M4.93 19.07l2.83-2.83"/><path d="M16.24 7.76l2.83-2.83"/>`,
  },
];
---
<Layout title="Our Services — Nakkashi Signature Painting">
  <PageHero
    eyebrow="Services"
    title="A full spectrum of premium painting & finishing services."
    lead="From signature textures to ShieldPro waterproofing — every Nakkashi service is delivered with the same standard of craftsmanship, material quality, and project care."
  />

  <!-- SIGNATURE SERVICES INTRO -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">Our Signature Services</div>
        <h2>Crafted for every space — <em>residential, commercial, hospitality.</em></h2>
        <p>
          Whether it's a single feature wall, a luxury villa, or an entire
          commercial fit-out — Nakkashi delivers premium results with master
          craftsmanship and uncompromising attention to detail.
        </p>
      </div>

      <div style="display:grid;gap:1.5rem;grid-template-columns:1fr">
        {services.map((s, i) => (
          <div class="reveal" style={`background:#fff;border:1px solid var(--line);border-radius:24px;padding:clamp(2rem,3.5vw,3rem);display:grid;grid-template-columns:90px 1fr auto;gap:2rem;align-items:start;box-shadow:var(--shadow-sm)`}>
            <div class="icon" style="width:80px;height:80px;border-radius:18px;background:linear-gradient(135deg,var(--cream),#fff);border:1px solid var(--line)">
              <svg viewBox="0 0 24 24" set:html={s.icon} style="width:36px;height:36px;stroke:var(--navy-deep);fill:none;stroke-width:1.6"></svg>
            </div>
            <div>
              <div style="display:flex;gap:.8rem;align-items:center;margin-bottom:.5rem">
                <span style="font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;font-weight:700;color:var(--gold-deep);background:rgba(224,170,62,.12);padding:.3rem .7rem;border-radius:50px">{s.tag}</span>
                <span style="font-family:var(--display);font-style:italic;color:var(--muted);font-size:.95rem">— 0{i + 1}</span>
              </div>
              <h3 style="font-family:var(--display);font-size:1.65rem;font-weight:500;color:var(--navy-deep);margin-bottom:.8rem">{s.title}</h3>
              <p style="color:var(--muted);font-size:1.02rem;margin-bottom:1.2rem">{s.desc}</p>
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:.5rem">
                {s.bullets.map(b => (
                  <div style="display:flex;gap:.5rem;align-items:center;font-size:.92rem;color:var(--navy-deep)">
                    <span style="width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0"></span>
                    <span>{b}</span>
                  </div>
                ))}
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:.6rem;align-items:flex-end">
              <a href="/quote" class="btn btn-gold" style="font-size:.88rem;padding:.7rem 1.3rem">Request Quote</a>
              <a href="/contact" style="font-size:.85rem;color:var(--gold-deep);font-weight:600;text-decoration:none">Talk to an Expert →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Who We Work With</div>
        <h2>Designed for the spaces that <em>matter most.</em></h2>
        <p>From private homes to flagship retail, our services adapt to your project scale, complexity, and design ambition.</p>
      </div>
      <div class="svc-grid">
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg></div>
          <h3>Homeowners</h3>
          <p>Independent homes, villas, and apartments looking for premium finishes with a personal touch.</p>
        </div>
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M2 22h20"/><path d="M6 18V8l6-4 6 4v10"/><path d="M10 18v-4h4v4"/></svg></div>
          <h3>Architects &amp; Designers</h3>
          <p>Trusted execution partner for design firms specifying premium textures and decorative finishes.</p>
        </div>
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6v6H9z"/></svg></div>
          <h3>Builders &amp; Developers</h3>
          <p>Show-flat finishes, premium wing handovers, and luxury project executions at scale.</p>
        </div>
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8 12h8M12 8v8"/></svg></div>
          <h3>Hospitality &amp; Retail</h3>
          <p>Hotels, restaurants, boutiques, and offices needing brand-aligned, durable signature finishes.</p>
        </div>
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M20 7l-8 4-8-4"/><rect x="3" y="5" width="18" height="14" rx="2"/></svg></div>
          <h3>Institutional Spaces</h3>
          <p>Schools, hospitals, and offices where durability, hygiene, and aesthetics need to coexist.</p>
        </div>
        <div class="svc-card reveal">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 2l3 6 6 1-4.5 4 1 6L12 16l-5.5 3 1-6L3 9l6-1z"/></svg></div>
          <h3>Heritage &amp; Restoration</h3>
          <p>Restoring historic walls and surfaces with techniques that respect the original character.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    heading="Tell us about your space — get a <em>tailored</em> quotation."
    text="Every Nakkashi project starts with understanding your vision. Send us your details and we'll respond within 24 hours with the next steps."
    primaryLabel="Start Your Project"
    primaryHref="/quote"
    secondaryLabel="See Our Process"
    secondaryHref="/process"
  />
</Layout>
