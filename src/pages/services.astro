---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import { withBase } from '../lib/url';
import { services, tiers } from '../data/services';

const steps = [
  { n: '01', title: 'Consultation', desc: 'An in-depth conversation covering your vision, style, and what success looks like for the project.' },
  { n: '02', title: 'Site Assessment', desc: 'On-site visit with measurements, surface evaluation, and moisture testing. Always complimentary.' },
  { n: '03', title: 'Design &amp; Texture Selection', desc: 'Curated samples, on-wall mock-ups, and digital previews before a single brush is lifted.' },
  { n: '04', title: 'Proposal &amp; Planning', desc: 'A clear, itemised quotation with timelines, materials, and crew allocation.' },
  { n: '05', title: 'Surface Preparation', desc: 'Cleaning, sanding, repair, and priming — the unsexy work that makes the finish extraordinary.' },
  { n: '06', title: 'Professional Application', desc: 'Trained applicators using premium materials and proven techniques for every signature finish.' },
  { n: '07', title: 'Quality Inspection', desc: 'A senior-led walk-through. Anything flagged is fixed before you ever see it.' },
  { n: '08', title: 'Project Handover', desc: 'Clean handover, care guide, and a complimentary 6-month inspection.' },
];

const assurances = [
  {
    title: 'Transparent Pricing',
    desc: 'No hidden costs. Every line item documented and explained — complete clarity from quotation to completion.',
    icon: `<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M7 15h4"/>`,
  },
  {
    title: 'Premium Materials',
    desc: 'High-quality products and proven systems from trusted premium manufacturers — never generic substitutes.',
    icon: `<path d="M12 2l3 6 6 1-4.5 4 1 6L12 16l-5.5 3 1-6L3 9l6-1z"/>`,
  },
  {
    title: 'Skilled Craftsmanship',
    desc: 'Experienced applicators delivering precision and consistency — continuously trained on new techniques.',
    icon: `<path d="M4 20l5-5"/><path d="M14 4l6 6-9 9H5v-6z"/><path d="M11 7l6 6"/>`,
  },
  {
    title: 'On-Time Delivery',
    desc: 'Professional planning that respects your time — clear timelines, and we stick to them.',
    icon: `<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>`,
  },
];

const privileges = [
  { n: '01', title: 'Complimentary Site Visit', desc: 'Experts visit your site, assess the space, and recommend the most suitable textures — free of charge.' },
  { n: '02', title: 'Free Designer Consultation', desc: 'Professional guidance on colour palettes, textures, and feature walls to bring your vision to life.' },
  { n: '03', title: 'Priority Scheduling', desc: 'Preferred project scheduling, dedicated coordination, and clear communication throughout.' },
  { n: '04', title: '6-Month Free Inspection', desc: 'Our commitment continues — a complimentary inspection after 6 months to ensure lasting beauty.' },
];
---
<Layout title="Our Services — Nakkashi Signature Painting">
  <PageHero
    eyebrow="Services"
    title="A full spectrum of premium painting & finishing services."
    lead="From signature textures to ShieldPro waterproofing — every Nakkashi service is delivered with the same standard of craftsmanship, material quality, and project care."
  />

  <!-- SERVICES -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">Our Signature Services</div>
        <h2>Six services. Three audiences. <em>One standard.</em></h2>
        <p>Every service below is delivered to the same premium standard — whether it's a home, a hotel, or a design specification.</p>
      </div>

      <div class="tier-legend reveal">
        <span class="tl-label">Tag legend:</span>
        {tiers.map(t => (
          <span class={`tl-chip tl-${t.key}`}>{t.label.replace('For ', '')}</span>
        ))}
      </div>

      <div class="sig-svc-grid">
        {services.map((s, i) => (
          <div class="sig-svc-card reveal">
            <div class="ssc-head">
              <div class="ssc-icon-wrap">
                <svg viewBox="0 0 24 24" set:html={s.icon} width="26" height="26" style="display:block;fill:none;stroke:var(--gold-soft);stroke-width:1.6;flex-shrink:0"></svg>
              </div>
              <div class="ssc-meta">
                <span class="ssc-tag">{s.tag}</span>
                <span class="ssc-num">0{i + 1}</span>
              </div>
            </div>
            <div class="ssc-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <div class="ssc-tiers" aria-label="Available for">
                {s.tiers.map(tk => {
                  const t = tiers.find(x => x.key === tk);
                  return t ? <span class={`ssc-tier-chip tl-${tk}`}>{t.label.replace('For ', '')}</span> : null;
                })}
              </div>
              <ul class="ssc-bullets">
                {s.bullets.map(b => (
                  <li>
                    <span class="ssc-dot"></span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
            <div class="ssc-foot">
              <a href={withBase('/quote')} class="btn btn-gold ssc-btn">Request Quote</a>
              <a href={withBase('/contact')} class="ssc-link">Talk to an Expert →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .sig-svc-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.8rem;
    }

    .sig-svc-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 24px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      box-shadow: var(--shadow-sm);
      transition: transform .35s, box-shadow .35s, border-color .35s;
    }

    .sig-svc-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
      border-color: rgba(224, 170, 62, .35);
    }

    .ssc-head {
      background: linear-gradient(135deg, var(--navy-deep) 0%, var(--navy-700) 100%);
      padding: 1.8rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      position: relative;
      overflow: hidden;
    }

    .ssc-head::after {
      content: '';
      position: absolute;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(224, 170, 62, .2), transparent 70%);
      top: -80px; right: -50px;
      pointer-events: none;
    }

    .ssc-icon-wrap {
      width: 58px; height: 58px;
      border-radius: 16px;
      background: rgba(224, 170, 62, .14);
      border: 1px solid rgba(224, 170, 62, .3);
      display: flex; align-items: center; justify-content: center;
      position: relative; z-index: 1;
      flex-shrink: 0;
    }

    .ssc-icon-wrap svg {
      width: 26px; height: 26px;
      stroke: var(--gold-soft);
      fill: none; stroke-width: 1.6;
    }

    .ssc-meta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: .5rem;
      position: relative; z-index: 1;
    }

    .ssc-tag {
      font-size: .66rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--gold);
      background: rgba(224, 170, 62, .14);
      border: 1px solid rgba(224, 170, 62, .3);
      padding: .28rem .7rem;
      border-radius: 50px;
    }

    .ssc-num {
      font-family: var(--display);
      font-style: italic;
      font-size: 2.4rem;
      color: rgba(247, 243, 234, .18);
      line-height: 1;
    }

    .ssc-body {
      padding: 1.8rem 2rem 1.4rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .ssc-body h3 {
      font-family: var(--display);
      font-size: 1.5rem;
      font-weight: 500;
      color: var(--navy-deep);
      margin-bottom: .65rem;
      line-height: 1.15;
    }

    .ssc-body p {
      color: var(--muted);
      font-size: .97rem;
      line-height: 1.6;
      margin-bottom: 1.4rem;
    }

    .ssc-bullets {
      list-style: none;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: .5rem .8rem;
      margin-top: auto;
    }

    .ssc-bullets li {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .9rem;
      color: var(--navy-deep);
    }

    .ssc-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    .ssc-foot {
      padding: 1.2rem 2rem 1.6rem;
      border-top: 1px solid var(--line);
      display: flex;
      align-items: center;
      gap: 1.2rem;
      flex-wrap: wrap;
    }

    .ssc-btn {
      font-size: .86rem;
      padding: .65rem 1.3rem;
    }

    .ssc-link {
      font-size: .86rem;
      color: var(--gold-deep);
      font-weight: 600;
      transition: color .2s;
    }

    .ssc-link:hover { color: var(--navy-deep); }

    @media (max-width: 900px) {
      .sig-svc-grid { grid-template-columns: 1fr; }
    }

    .tier-legend {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: .6rem;
      margin: 0 auto 2.2rem;
      max-width: 720px;
    }
    .tl-label {
      font-size: .72rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
      margin-right: .4rem;
    }
    .tl-chip,
    .ssc-tier-chip {
      display: inline-flex;
      align-items: center;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: .3rem .7rem;
      border-radius: 50px;
      border: 1px solid transparent;
    }
    .tl-residential { background: rgba(2, 32, 68, .08); color: var(--navy-deep); border-color: rgba(2, 32, 68, .2); }
    .tl-commercial  { background: rgba(224, 170, 62, .14); color: var(--gold-deep); border-color: rgba(224, 170, 62, .35); }
    .tl-trade       { background: linear-gradient(135deg, rgba(224, 170, 62, .18), rgba(2, 32, 68, .12)); color: var(--navy-deep); border-color: rgba(224, 170, 62, .4); }

    .ssc-tiers {
      display: flex;
      flex-wrap: wrap;
      gap: .35rem;
      margin: -.4rem 0 1.2rem;
    }
    .ssc-tier-chip {
      font-size: .6rem;
      padding: .22rem .55rem;
      letter-spacing: .08em;
    }
  </style>

  <!-- 8-STEP PROCESS -->
  <section class="section bg-dark process-section">
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="sec-head center reveal" style="position:relative;z-index:2">
        <div class="eyebrow">Our Process</div>
        <h2>Eight steps. <em>One standard.</em></h2>
        <p>From first call to final walk-through — so you always know what's happening, when, and why.</p>
      </div>

      <div class="process-flow reveal">
        {steps.map((s, i) => (
          <div class="pf-step">
            <div class="pf-node">
              <span class="pf-num">{s.n}</span>
            </div>
            <h3 set:html={s.title}></h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="stat-strip">
        <div class="stat-item"><div class="num">24h</div><div class="lbl">Quote Turnaround</div></div>
        <div class="stat-item"><div class="num">100%</div><div class="lbl">Transparent Pricing</div></div>
        <div class="stat-item"><div class="num">6 mo</div><div class="lbl">Free Inspection</div></div>
        <div class="stat-item"><div class="num">15 yr</div><div class="lbl">Of Craft Expertise</div></div>
      </div>
    </div>
  </section>

  <style>
    .process-section .process-flow {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2.4rem 1.5rem;
      margin-top: 2.5rem;
    }
    .process-section .pf-step {
      position: relative;
      text-align: center;
      padding: 0 0.5rem;
    }
    /* horizontal connector between tiles in same row */
    .process-section .pf-step::after {
      content: '';
      position: absolute;
      top: 33px;
      left: calc(50% + 36px);
      right: calc(-50% + 36px);
      height: 1px;
      background: linear-gradient(90deg, rgba(224, 170, 62, 0.55), rgba(224, 170, 62, 0.1));
      pointer-events: none;
    }
    .process-section .pf-step:nth-child(4n)::after { display: none; }

    .process-section .pf-node {
      width: 66px;
      height: 66px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #F1C56F, #C8902A 75%);
      display: grid;
      place-items: center;
      margin: 0 auto 1.1rem;
      position: relative;
      z-index: 2;
      box-shadow:
        0 0 0 6px rgba(224, 170, 62, 0.12),
        0 12px 24px rgba(0, 0, 0, 0.35);
    }
    .process-section .pf-num {
      font-family: var(--display, 'Fraunces', serif);
      font-style: italic;
      font-weight: 600;
      font-size: 1.5rem;
      color: #022044;
      letter-spacing: 0.02em;
    }
    .process-section .pf-step h3 {
      font-family: var(--display, 'Fraunces', serif);
      font-size: 1.1rem;
      font-weight: 500;
      color: #fff;
      margin: 0 0 0.45rem;
      line-height: 1.2;
    }
    .process-section .pf-step p {
      font-size: 0.88rem;
      color: rgba(247, 243, 234, 0.72);
      line-height: 1.55;
      margin: 0;
      max-width: 28ch;
      margin-inline: auto;
    }

    @media (max-width: 960px) {
      .process-section .process-flow { grid-template-columns: repeat(2, 1fr); gap: 2.2rem 1.2rem; }
      .process-section .pf-step:nth-child(4n)::after { display: block; }
      .process-section .pf-step:nth-child(2n)::after { display: none; }
    }
    @media (max-width: 560px) {
      .process-section .process-flow { grid-template-columns: 1fr; gap: 1.6rem; }
      .process-section .pf-step::after { display: none !important; }
      .process-section .pf-step { display: grid; grid-template-columns: 48px 1fr; text-align: left; gap: 1rem; align-items: start; }
      .process-section .pf-node { margin: 0; width: 48px; height: 48px; box-shadow: 0 0 0 4px rgba(224,170,62,.12), 0 8px 16px rgba(0,0,0,.3); }
      .process-section .pf-num { font-size: 1.1rem; }
      .process-section .pf-step h3 { align-self: center; }
      .process-section .pf-step p { margin-inline: 0; max-width: none; grid-column: 2; }
    }
  </style>

  <!-- THE NAKKASHI ASSURANCE -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">The Nakkashi Assurance</div>
        <h2>Four pillars that define <em>every</em> Nakkashi project.</h2>
      </div>

      <div class="assure-grid">
        {assurances.map((a, i) => (
          <div class="assure-card reveal">
            <div class="num">{String(i + 1).padStart(2, '0')}</div>
            <div class="icon-circle">
              <svg viewBox="0 0 24 24" set:html={a.icon}></svg>
            </div>
            <h3>{a.title}</h3>
            <p>{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CUSTOMER PRIVILEGES -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal wide">
        <div class="eyebrow">Customer Privileges</div>
        <h2>Complimentary benefits — for every client.</h2>
      </div>

      <div class="assure-grid">
        {privileges.map(p => (
          <div class="assure-card reveal" style="background:linear-gradient(160deg,#fff,var(--cream))">
            <div class="num">{p.n}</div>
            <div class="icon-circle" style="background:linear-gradient(135deg,var(--navy-deep),var(--navy-700))">
              <svg viewBox="0 0 24 24"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="9"/></svg>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABand
    heading="Tell us about your space — get a <em>tailored</em> quotation."
    text="Every Nakkashi project starts with understanding your vision. Send us your details and we'll respond within 24 hours."
    primaryLabel="Start Your Project"
    primaryHref="/quote"
    secondaryLabel="Talk to Us"
    secondaryHref="/contact"
  />
</Layout>
