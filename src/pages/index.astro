---
import Layout from '../layouts/Layout.astro';
import ContractorMarquee from '../components/ContractorMarquee.astro';
import CTABand from '../components/CTABand.astro';
import LeadPopup from '../components/LeadPopup.astro';
import { withBase } from '../lib/url';

const services = [
  {
    cat: 'texture',
    title: 'Signature Texture Collection',
    desc: 'Artistic textures designed to bring depth, character, and sophistication to every surface.',
    href: '/services',
    label: 'Explore textures',
    icon: '<path d="M4 20l5-5"/><path d="M14 4l6 6-9 9H5v-6z"/><path d="M11 7l6 6"/>',
  },
  {
    cat: 'interior',
    title: 'Elite Interior Finishes',
    desc: 'Premium painting solutions crafted to deliver flawless aesthetics and enduring beauty for every room.',
    href: '/services',
    label: 'View interior work',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/>',
  },
  {
    cat: 'artistry',
    title: 'Luxury Surface Artistry',
    desc: 'Exclusive decorative finishes inspired by contemporary architecture and high-end luxury interiors.',
    href: '/services',
    label: 'See finishes',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 3a9 9 0 010 18"/><path d="M3 12h18"/>',
  },
  {
    cat: 'statement',
    title: 'Statement Wall Creations',
    desc: 'Bespoke feature walls designed to become the focal point of exceptional, memorable spaces.',
    href: '/services',
    label: 'View statement walls',
    icon: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>',
  },
  {
    cat: 'waterproof',
    title: 'ShieldPro Waterproofing',
    desc: 'Advanced protection systems engineered to safeguard structures from moisture, seepage, and damage.',
    href: '/services',
    label: 'Learn protection',
    icon: '<path d="M12 2s7 6 7 11a7 7 0 01-14 0c0-5 7-11 7-11z"/>',
  },
  {
    cat: 'consultancy',
    title: 'Design & Finish Consultancy',
    desc: 'Expert guidance in selecting textures, finishes, and colour palettes that align with your vision.',
    href: '/services',
    label: 'Book consultation',
    icon: '<circle cx="13.5" cy="6.5" r="2.5"/><circle cx="6.5" cy="11.5" r="2.5"/><circle cx="17" cy="14" r="2.5"/><path d="M12 22a3 3 0 003-3c0-1.5-3-4-3-4"/>',
  },
];

const trending = [
  { title: 'Royale Play Stucco',    tag: 'Texture',  off: '20% OFF',  from: '₹28', desc: 'Hand-troweled stucco with subtle metallic catch.', tone: 'gold' },
  { title: 'Italian Marmorino',     tag: 'Premium',  off: '15% OFF',  from: '₹65', desc: 'Polished lime-based finish with marble depth.',      tone: 'cream' },
  { title: 'Metallic Gold Wash',    tag: 'Signature',off: 'NEW',      from: '₹42', desc: 'Hand-applied gold glaze for accent walls.',         tone: 'bronze' },
  { title: 'Limewash Estate',       tag: 'Classic',  off: '10% OFF',  from: '₹22', desc: 'Breathable mineral finish with old-world charm.',   tone: 'navy' },
];
---
<Layout title="Nakkashi — Premium Painting & Texture Execution Partner">
  <LeadPopup />

  {/* 1) BRAND/CONTRACTOR MARQUEE — hidden for now, re-enable by uncommenting */}
  {/* <ContractorMarquee /> */}

  <!-- 2) HERO -->
  <section class="hero" id="home">
    <div class="hero-grain"></div>
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="hero-inner">
        <div class="hero-copy">
          <div class="guarantee-badge" role="note" aria-label="6-month workmanship guarantee, an India-first commitment">
            <span class="gb-dot" aria-hidden="true"></span>
            <svg class="gb-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
              <path d="M8.5 12.2l2.6 2.6L16 9.8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="gb-text">
              <strong>India-First</strong>
              <span>6-Month Workmanship Guarantee</span>
            </span>
          </div>
          <div class="hero-eyebrow eyebrow">
            <span class="bar"></span> Premium Painting &amp; Texture Execution Partner
          </div>
          <h1>
            <span class="accent">Transforming</span> Walls<br />
            Into Signature Spaces.
          </h1>
          <p class="lead">
            We specialize in the execution of premium painting, textures, and
            decorative finishes using trusted products from leading brands such
            as Asian Paints, Berger, Dulux, Birla Opus, and Sirca.
          </p>
          <div class="hero-cta">
            <a href={withBase('/quote')} class="btn btn-gold">
              Get a Free Quote
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
            <a href={withBase('/services')} class="btn btn-outline-gold">Explore Our Services</a>
          </div>
          <div class="hero-stats">
            <div class="stat"><div class="num">350+</div><div class="lbl">Spaces Transformed</div></div>
            <div class="stat"><div class="num">15<span style="font-size:1.3rem">yrs</span></div><div class="lbl">Of Craftsmanship</div></div>
            <div class="stat"><div class="num">50+</div><div class="lbl">Skilled Craftsmen</div></div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="swatch-stack">
            <div class="swatch s1">
              <div class="chip"></div>
              <div class="meta"><div class="h">Midnight Estate</div><div class="c">#022044</div></div>
            </div>
            <div class="swatch s3">
              <div class="chip"></div>
              <div class="meta"><div class="h">Warm Linen</div><div class="c">#F7F3EA</div></div>
            </div>
            <div class="swatch s2">
              <div class="chip"></div>
              <div class="meta"><div class="h">Signature Gold</div><div class="c">#E0AA3E</div></div>
            </div>
          </div>
          <div class="float-badge fb-1">
            <svg viewBox="0 0 24 24" fill="none" stroke="#E0AA3E" stroke-width="1.8">
              <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" />
            </svg>
            90% On-Time Site Handovers
          </div>
          <div class="float-badge fb-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="#022044" stroke-width="1.8">
              <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" />
            </svg>
            Free Interior Design Consultation
          </div>
        </div>
      </div>
    </div>
    <svg class="hero-drip" viewBox="0 0 1440 90" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path fill="currentColor" d="M0,40 C180,80 320,10 480,38 C600,60 660,30 760,42 C740,70 745,82 770,84 C795,86 800,72 782,52 C880,44 980,72 1120,46 C1280,18 1360,66 1440,44 L1440,90 L0,90 Z"/>
    </svg>
  </section>

  <!-- INTRO / ABOUT SNIPPET -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="content-grid">
        <div class="image-card reveal">
          <span class="overlay-tag">Where creativity meets craftsmanship.</span>
        </div>
        <div class="reveal">
          <div class="eyebrow">About Nakkashi</div>
          <h2>Walls are more than surfaces — they're the <em>identity</em> of a space.</h2>
          <p>
            Nakkashi is a premium end-to-end execution partner brand dedicated to
            transforming spaces through exceptional craftsmanship, innovative
            textures, and professional execution. Every project is executed by
            skilled professionals using premium materials and industry-leading
            techniques.
          </p>
          <p>
            We work closely with homeowners, architects, interior designers,
            builders, and businesses to create spaces that leave a lasting
            impression — from contemporary textures to timeless finishes.
          </p>
          <a href={withBase('/about')} class="btn btn-ghost" style="margin-top:.8rem">
            Discover Our Story
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- (1) OUR SIGNATURE SERVICES — TOP -->
  <section class="section bg-cream" id="services">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">Our Signature Services</div>
        <h2>A full spectrum of premium painting &amp; finishing.</h2>
        <p>
          Whether it's a single feature wall or a whole estate, our crews deliver
          clean lines, durable coats, and a finish you'll be proud to sign your
          name to.
        </p>
      </div>

      <div class="svc-grid">
        {services.map(s => (
          <div class={`svc-card cat-${s.cat} reveal`}>
            <div class="icon">
              <svg viewBox="0 0 24 24" set:html={s.icon}></svg>
            </div>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <a href={withBase(s.href)} class="more">{s.label} <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- (2) LEAD FORM — MIDDLE OF HOMEPAGE -->
  <section class="section lead-section" id="lead">
    <div class="wrap">
      <div class="lead-card reveal">
        <div class="lead-side">
          <div class="lead-eyebrow">Get a Free Design Consultation</div>
          <h2>Tell us about your space — <em>we'll handle the rest.</em></h2>
          <p>
            Share a few details and our project team will call you within 24 hours
            with a curated recommendation, transparent pricing, and a complimentary
            site visit.
          </p>
          <ul class="lead-perks">
            <li><span class="dot"></span>Free interior design consultation</li>
            <li><span class="dot"></span>90% on-time site handovers</li>
            <li><span class="dot"></span>Premium texture execution from ₹18/sq.ft.</li>
            <li><span class="dot"></span>50+ skilled craftsmen on hand</li>
          </ul>
        </div>

        <form class="lead-form" id="inlineLeadForm" onsubmit="event.preventDefault(); this.classList.add('done');">
          <div class="lead-tag">Step 1 of 1 · 60-second form</div>
          <h3>Book a Free Site Visit</h3>

          <div class="lead-segment">
            <span class="lead-label">Property Type</span>
            <div class="chip-row">
              <label class="chip"><input type="radio" name="ptype" value="Apartment" checked /><span>Apartment</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Villa" /><span>Villa / Bungalow</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Independent" /><span>Independent House</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Commercial" /><span>Commercial</span></label>
            </div>
          </div>

          <div class="lead-segment">
            <span class="lead-label">Size</span>
            <div class="chip-row">
              <label class="chip"><input type="radio" name="bhk" value="1BHK" /><span>1 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="2BHK" checked /><span>2 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="3BHK" /><span>3 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="4BHK+" /><span>4 BHK +</span></label>
            </div>
          </div>

          <div class="lead-fields">
            <label>
              <span>Full Name *</span>
              <input type="text" name="name" required placeholder="Your full name" />
            </label>
            <label>
              <span>Phone *</span>
              <input type="tel" name="phone" required placeholder="+91 74006 40093" />
            </label>
            <label>
              <span>City</span>
              <input type="text" name="city" placeholder="e.g. New Delhi" />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" placeholder="you@example.com" />
            </label>
          </div>

          <button type="submit" class="lead-submit">
            Book Free Consultation
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
          <div class="lead-fine">By submitting, you agree to be contacted by our team. No spam, ever.</div>

          <div class="lead-thanks">
            <div class="check">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg>
            </div>
            <h4>Thanks — we'll be in touch!</h4>
            <p>Our project team will reach out within 24 hours.</p>
          </div>
        </form>
      </div>
    </div>
  </section>

  <!-- (3) HOW WE WORK -->
  <section class="section bg-dark" id="process">
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="sec-head reveal" style="margin-bottom:0">
        <div class="eyebrow">How We Work</div>
        <h2>Planned with precision. <em>Executed with excellence.</em></h2>
        <p>A transparent process from first call to final walk-through.</p>
      </div>
      <div class="proc-grid">
        <div class="proc-step reveal"><div class="n">01</div><h3>Consultation</h3><p>Understanding your vision, requirements, style preferences, and project goals.</p></div>
        <div class="proc-step reveal"><div class="n">02</div><h3>Site Assessment</h3><p>Detailed inspection and measurement to evaluate surfaces and project requirements.</p></div>
        <div class="proc-step reveal"><div class="n">03</div><h3>Design Selection</h3><p>Curating the ideal textures, finishes, and colour palettes for your space.</p></div>
        <div class="proc-step reveal"><div class="n">04</div><h3>Proposal &amp; Plan</h3><p>Providing a transparent quotation, project timeline, and clear execution plan.</p></div>
      </div>
      <div style="text-align:center;margin-top:2.5rem;position:relative;z-index:2">
        <a href={withBase('/services')} class="btn btn-outline-gold">See Full 8-Step Process</a>
      </div>
    </div>
  </section>

  <!-- (4) TRENDING TEXTURES WITH OFFERS -->
  <section class="section bg-paper" id="trending">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">Trending This Season</div>
        <h2>Trending textures <em>with offers.</em></h2>
        <p>Limited-time pricing on our most-loved finishes — book before they go.</p>
      </div>
      <div class="trend-grid">
        {trending.map(t => (
          <div class={`trend-card tone-${t.tone} reveal`}>
            <div class="trend-thumb" aria-hidden="true">
              <span class="trend-badge">{t.off}</span>
            </div>
            <div class="trend-body">
              <div class="trend-meta">
                <span class="trend-tag">{t.tag}</span>
                <span class="trend-from">from <strong>{t.from}</strong>/sq.ft.</span>
              </div>
              <h3>{t.title}</h3>
              <p>{t.desc}</p>
              <a href={withBase('/quote')} class="trend-cta">Book this finish <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- (5) PALETTE -->
  <section class="section bg-cream">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">The Signature Palette</div>
        <h2>Colours curated to live <em>beautifully</em> together.</h2>
        <p>
          Hover to explore the shades that define a Nakkashi finish — from deep
          estate navies to warm, gilded golds.
        </p>
      </div>
      <div class="colour-band reveal">
        <div class="tile" style="background:#00173C"><div class="nm">Estate Navy</div><div class="hx">#00173C</div></div>
        <div class="tile" style="background:#022044"><div class="nm">Midnight</div><div class="hx">#022044</div></div>
        <div class="tile" style="background:#163152"><div class="nm">Slate Blue</div><div class="hx">#163152</div></div>
        <div class="tile" style="background:#E0AA3E"><div class="nm">Signature Gold</div><div class="hx">#E0AA3E</div></div>
        <div class="tile" style="background:#EBC36A"><div class="nm">Soft Brass</div><div class="hx">#EBC36A</div></div>
        <div class="tile" style="background:#F7F3EA;color:#022044">
          <div class="nm" style="color:#022044">Warm Linen</div>
          <div class="hx" style="color:#5C6B82">#F7F3EA</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SHOWCASE / GALLERY PREVIEW -->
  <section class="section bg-paper" id="showcase">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">Recent Work</div>
        <h2>Transformations, <em>signed by Nakkashi.</em></h2>
        <p>A glimpse of homes, offices, and hospitality spaces where colour, craft and care came together.</p>
      </div>
      <div class="gallery reveal">
        <div class="gtile g1"><div class="gmeta"><div class="t">Hillside Villa Exterior</div><div class="s">Exterior · Weather-shield</div></div></div>
        <div class="gtile g2"><div class="gmeta"><div class="t">Gilded Living Room</div><div class="s">Interior · Metallic Accent</div></div></div>
        <div class="gtile g3"><div class="gmeta"><div class="t">Master Suite</div><div class="s">Interior · Royale</div></div></div>
        <div class="gtile g4"><div class="gmeta" style="color:#022044"><div class="t">Feature Wall</div><div class="s">Texture</div></div></div>
        <div class="gtile g5"><div class="gmeta"><div class="t">Boutique Café Fit-out</div><div class="s">Commercial · Full Repaint</div></div></div>
      </div>
      <div style="text-align:center;margin-top:2rem">
        <a href={withBase('/gallery')} class="btn btn-ghost">View Full Gallery</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section bg-cream" id="reviews">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Client Stories</div>
        <h2>Loved by homeowners and designers across the city.</h2>
      </div>
      <div class="testi-grid">
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>The crew was punctual, tidy and genuinely skilled. Our home looks like something out of a magazine — the gold accent wall is everyone's favourite.</p>
          <div class="who"><div class="av">RA</div><div><div class="nm">Riya Arora</div><div class="rl">Greater Kailash</div></div></div>
        </div>
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>From the colour consultation to the final coat, everything felt premium. No mess, no delays, and the finish is absolutely flawless.</p>
          <div class="who"><div class="av">VM</div><div><div class="nm">Vikram Mehta</div><div class="rl">Dwarka</div></div></div>
        </div>
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>We had recurring seepage for years. Nakkashi's waterproofing fixed it completely and the exterior still looks fresh after two monsoons.</p>
          <div class="who"><div class="av">SK</div><div><div class="nm">Sunita Kapoor</div><div class="rl">Rohini</div></div></div>
        </div>
      </div>
    </div>
  </section>

  <CTABand />
</Layout>
