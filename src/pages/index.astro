---
import Layout from '../layouts/Layout.astro';
import ContractorMarquee from '../components/ContractorMarquee.astro';
import CTABand from '../components/CTABand.astro';
import LeadPopup from '../components/LeadPopup.astro';
import { withBase } from '../lib/url';
import { services, tiers } from '../data/services';

const trending = [
  { title: 'Venetian Gold',    tag: 'Signature', badge: 'Editor’s Pick', img: '/Texture 1 EXCL.webp',  desc: 'Richly textured gold-toned finish with timeless Italian character.', tone: 'gold' },
  { title: 'Pearl Essence',    tag: 'Premium',   badge: 'Most Loved',        img: '/Texture 2 EXCl.webp',  desc: 'Soft pearlescent finish that catches light with subtle elegance.', tone: 'cream' },
  { title: 'Royal Damask',     tag: 'Texture',   badge: 'Signature',         img: '/Texture 3 EXCL.webp',  desc: 'Intricate raised pattern that adds depth and grandeur to any wall.', tone: 'bronze' },
  { title: 'Azure Limewash',   tag: 'Classic',   badge: 'New This Season',   img: '/Texture 4 EXCL.webp',  desc: 'Breathable mineral wash in deep navy with old-world character.', tone: 'navy' },
];
---
<Layout title="Nakkashi   Premium Painting & Texture Execution Partner" preloadHero={true}>
  <LeadPopup />

  {/* 1) BRAND/CONTRACTOR MARQUEE   hidden for now, re-enable by uncommenting */}
  {/* <ContractorMarquee /> */}

  <!-- 2) HERO -->
  <section class="hero" id="home">
    <div class="hero-img-overlay">
      <img
        src={withBase('/hero section.webp')}
        alt=""
        width="1600"
        height="900"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <div class="hero-grain"></div>
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="hero-inner">
        <div class="hero-copy">
          <div class="guarantee-badge" role="note" aria-label="6-month workmanship guarantee, an India-first commitment">
            <span class="gb-dot" aria-hidden="true"></span>
            <svg class="gb-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5l8-3z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
              <path d="M8.5 12.2l2.6 2.6L16 9.8" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="gb-text">
              <strong>India-First</strong>
              <span>6-Month Workmanship Guarantee</span>
            </span>
          </div>
          <div class="hero-eyebrow eyebrow">
            For Homes · Workspaces · Design Experts
          </div>
          <h1>
            <span class="accent">Transforming</span> Walls<br />
            Into Signature Spaces.
          </h1>
          <p class="lead">
            Nakkashi is a premium painting &amp; texture execution partner  
            trusted by homeowners, commercial spaces, and India's leading
            designers for signature finishes delivered on time, every time.
          </p>
          <div class="hero-cta">
            <a href={withBase('/quote')} class="btn btn-gold">
              Get a Free Quote
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
            <a href={withBase('/services')} class="btn btn-outline-gold">Explore Our Services</a>
          </div>
          <div class="hero-stats">
            <div class="stat"><div class="num">350+</div><div class="lbl">Spaces Transformed</div></div>
            <div class="stat"><div class="num">15<span style="font-size:1.3rem">yrs</span></div><div class="lbl">Of Craftsmanship</div></div>
            <div class="stat"><div class="num">50+</div><div class="lbl">Skilled Craftsmen</div></div>
          </div>
        </div>

        <div class="hero-visual">
          <div class="swatch-stack">
            <div class="swatch s1">
              <div class="chip"><img src={withBase('/Texture 3.webp')} alt="Aura Finish texture"  loading="lazy" decoding="async" /></div>
              <div class="meta"><div class="h">Aura Finish</div><div class="c">Premium Finish</div></div>
            </div>
            <div class="swatch s3">
              <div class="chip"><img src={withBase('/Texture 2.webp')} alt="Raj Hans texture"  loading="lazy" decoding="async" /></div>
              <div class="meta"><div class="h">Raj Hans</div><div class="c">Luxury Finish</div></div>
            </div>
            <div class="swatch s2">
              <div class="chip"><img src={withBase('/Texture 1.webp')} alt="Mandakini Finish texture"  loading="lazy" decoding="async" /></div>
              <div class="meta"><div class="h">Mandakini Finish</div><div class="c">Signature Texture</div></div>
            </div>
          </div>
          <div class="float-badge fb-1">
            <svg viewBox="0 0 24 24" fill="none" stroke="#E0AA3E" stroke-width="1.8">
              <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" />
            </svg>
            Late?   On-Time Guarantee
          </div>
          <div class="float-badge fb-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="#022044" stroke-width="1.8">
              <path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" />
            </svg>
            Free Interior Designer Consultation
          </div>
        </div>
      </div>
    </div>
    <svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
      <defs>
        <clipPath id="heroWaveClip" clipPathUnits="objectBoundingBox">
          <path d="M0,0.444 C0.125,0.889 0.222,0.111 0.333,0.422 C0.417,0.667 0.458,0.333 0.528,0.467 C0.514,0.778 0.517,0.911 0.535,0.933 C0.552,0.956 0.556,0.8 0.543,0.578 C0.611,0.489 0.681,0.8 0.778,0.511 C0.889,0.2 0.944,0.733 1,0.489 L1,1 L0,1 Z"/>
        </clipPath>
      </defs>
    </svg>
    <div class="hero-drip"></div>
  </section>

  <!-- (4) TRENDING TEXTURES WITH OFFERS -->
  <section class="section bg-paper" id="trending">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">Trending This Season</div>
        <h2>The finishes clients <em>keep asking for.</em></h2>
        <p>Our most-specified textures   the ones designers and homeowners come back to time after time.</p>
      </div>
      <div class="trend-grid">
        {trending.map(t => (
          <div class={`trend-card tone-${t.tone} reveal`}>
            <div class="trend-thumb">
              <img src={withBase(t.img)} alt={t.title}  loading="lazy" decoding="async" />
              <span class="trend-badge">{t.badge}</span>
            </div>
            <div class="trend-body">
              <div class="trend-meta">
                <span class="trend-tag">{t.tag}</span>
              </div>
              <h3>{t.title}</h3>
              <p>{t.desc}</p>
              <a href={withBase('/quote')} class="trend-cta">Book this finish <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INTRO / ABOUT SNIPPET -->
  <section class="section bg-paper" style="background: #E8E2D5;">
    <div class="wrap">
      <div class="content-grid">
        <div class="image-card reveal">
          <img src={withBase('/About us page.webp')} alt="Nakkashi craftsmanship"  loading="lazy" decoding="async" />
        </div>
        <div class="reveal">
          <div class="eyebrow">About Nakkashi</div>
          <h2>Walls are more than surfaces   they're the <em>identity</em> of a space.</h2>
          <p>
            Nakkashi is a premium end-to-end execution partner brand dedicated to
            transforming spaces through exceptional craftsmanship, innovative
            textures, and professional execution. Every project is executed by
            skilled professionals using premium materials and industry-leading
            techniques.
          </p>
          <p>
            We work closely with homeowners, architects, interior designers,
            builders, and businesses to create spaces that leave a lasting
            impression   from contemporary textures to timeless finishes.
          </p>
          <p class="founder-hook">
            <span class="fh-tag">Founder-led</span>
            Trained with <strong>Asian Paints</strong> &amp; certified applicators for <strong>Birla Opus</strong>   15+ years of hands-on execution before Nakkashi.
          </p>
          <a href={withBase('/about')} class="btn btn-ghost" style="margin-top:.8rem">
            Discover Our Story
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE WORK WITH   3-TIER AUDIENCE STORY -->
  <section class="section bg-paper" id="who-we-work-with">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Who We Work With</div>
        <h2>Three audiences. <em>One standard of craft.</em></h2>
        <p>Whether you're finishing a home, opening a hotel, or specifying for a client   Nakkashi delivers the same premium execution, tailored to how you work.</p>
      </div>

      <div class="tier-grid">
        {tiers.map(t => (
          <div class={`tier-card tier-${t.key} reveal`}>
            <div class="tier-label">{t.label}</div>
            <h3>{t.tagline}</h3>
            <p>{t.desc}</p>
            <a href={withBase(t.key === 'trade' ? '/trade' : '/services')} class="more">
              {t.key === 'residential' ? 'Explore for homes' : t.key === 'commercial' ? 'Explore commercial' : 'Join the trade program'}
              <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .tier-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.6rem;
      margin-top: 2.5rem;
    }
    .tier-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 2rem 1.8rem;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      transition: transform .35s, box-shadow .35s, border-color .35s;
    }
    .tier-card::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(90deg, var(--gold), var(--gold-deep));
    }
    .tier-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
      border-color: rgba(224, 170, 62, .35);
    }
    .tier-card .tier-label {
      font-size: .68rem;
      letter-spacing: .22em;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--gold-deep);
      margin-bottom: .8rem;
    }
    .tier-card h3 {
      font-family: var(--display);
      font-size: 1.35rem;
      font-weight: 500;
      color: var(--navy-deep);
      line-height: 1.2;
      margin-bottom: .8rem;
    }
    .tier-card p {
      color: var(--muted);
      font-size: .95rem;
      line-height: 1.6;
      margin-bottom: 1.2rem;
      flex: 1;
    }
    .tier-card .more {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      color: var(--gold-deep);
      font-weight: 600;
      font-size: .9rem;
      text-decoration: none;
      transition: gap .2s, color .2s;
    }
    .tier-card .more svg {
      width: 14px; height: 14px;
      fill: none; stroke: currentColor; stroke-width: 2;
    }
    .tier-card .more:hover { color: var(--navy-deep); gap: .7rem; }
    .tier-card.tier-trade {
      background: linear-gradient(160deg, #fff, #FAF4E6);
      border-color: rgba(224, 170, 62, .3);
    }
    @media (max-width: 900px) {
      .tier-grid { grid-template-columns: 1fr; }
    }

    .founder-hook {
      display: flex;
      align-items: flex-start;
      gap: .7rem;
      margin-top: 1rem !important;
      padding: .9rem 1.1rem;
      background: rgba(224, 170, 62, .1);
      border-left: 3px solid var(--gold);
      border-radius: 0 10px 10px 0;
      font-size: .92rem !important;
      color: var(--navy-deep) !important;
      line-height: 1.5;
    }
    .fh-tag {
      flex-shrink: 0;
      font-size: .62rem;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-weight: 700;
      color: var(--gold-deep);
      background: #fff;
      padding: .25rem .55rem;
      border-radius: 50px;
      align-self: flex-start;
      margin-top: 2px;
    }
    .founder-hook strong { color: var(--gold-deep); }
  </style>

  <!-- (1) OUR SIGNATURE SERVICES   TOP -->
  <section class="section bg-cream" id="services">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">Our Signature Services</div>
        <h2>Where Every Wall Becomes a Masterpiece.</h2>
        <p>
          Exclusive textures, luxury finishes, and uncompromising craftsmanship creating 
          spaces that are as unique as the people who live in them.
        </p>
      </div>

      <div class="svc-grid">
        {services.map(s => (
          <div class={`svc-card cat-${s.cat} reveal`}>
            <div class="icon">
              <svg viewBox="0 0 24 24" set:html={s.icon}></svg>
            </div>
            <h3>{s.title}</h3>
            <p>{s.shortDesc}</p>
            <a href={withBase(s.href)} class="more">{s.label} <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- (2) LEAD FORM   MIDDLE OF HOMEPAGE -->
  <section class="section lead-section" id="lead">
    <div class="wrap">
      <div class="lead-card reveal">
        <div class="lead-side">
          <div class="lead-eyebrow">Get a Free Design Consultation</div>
          <h2>Tell us about your space   <em>we'll handle the rest.</em></h2>
          <p>
            Share a few details and our project team will call you within 24 hours
            with a curated recommendation, transparent pricing, and a complimentary
            site visit.
          </p>
          <ul class="lead-perks">
            <li><span class="dot"></span>Free interior design consultation</li>
            <li><span class="dot"></span><strong>Late? It's Free</strong>   written on-time guarantee</li>
            <li><span class="dot"></span>Transparent, tier-based pricing after your site visit</li>
            <li><span class="dot"></span>50+ skilled craftsmen on hand</li>
          </ul>
        </div>

        <form class="lead-form" id="inlineLeadForm" method="POST" action="https://formspree.io/f/xlgypabo">
          <input type="hidden" name="_subject" value="New Lead   Nakkashi Free Site Visit" />
          <div class="lead-tag">Step 1 of 1 · 60-second form</div>
          <h3>Book a Free Site Visit</h3>

          <div class="lead-segment">
            <span class="lead-label">Property Type</span>
            <div class="chip-row">
              <label class="chip"><input type="radio" name="ptype" value="Apartment" checked /><span>Apartment</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Villa" /><span>Villa / Bungalow</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Independent" /><span>Independent House</span></label>
              <label class="chip"><input type="radio" name="ptype" value="Commercial" /><span>Commercial</span></label>
            </div>
          </div>

          <div class="lead-segment">
            <span class="lead-label">Size</span>
            <div class="chip-row">
              <label class="chip"><input type="radio" name="bhk" value="1BHK" /><span>1 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="2BHK" checked /><span>2 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="3BHK" /><span>3 BHK</span></label>
              <label class="chip"><input type="radio" name="bhk" value="4BHK+" /><span>4 BHK +</span></label>
            </div>
          </div>

          <div class="lead-fields">
            <label>
              <span>Full Name *</span>
              <input type="text" name="name" required placeholder="Your full name" />
            </label>
            <label>
              <span>Phone *</span>
              <input type="tel" name="phone" required placeholder="+91 74006 40093" />
            </label>
            <label>
              <span>City</span>
              <input type="text" name="city" placeholder="e.g. New Delhi" />
            </label>
            <label>
              <span>Email</span>
              <input type="email" name="email" placeholder="you@example.com" />
            </label>
          </div>

          <button type="submit" class="lead-submit">
            Book Free Consultation
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>
          <div class="lead-fine">By submitting, you agree to be contacted by our team. No spam, ever.</div>

          <div class="lead-thanks">
            <div class="check">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg>
            </div>
            <h4>Thanks   we'll be in touch!</h4>
            <p>Our project team will reach out within 24 hours.</p>
          </div>
        </form>
        <script is:inline>
          document.getElementById('inlineLeadForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            try {
              const res = await fetch(this.action, {
                method: 'POST', body: new FormData(this),
                headers: { 'Accept': 'application/json' }
              });
              if (res.ok) { this.classList.add('done'); }
              else { throw new Error(); }
            } catch {
              alert('Something went wrong. Please try again or call us directly.');
            }
          });
        </script>
      </div>
    </div>
  </section>

  <!-- (3) HOW WE WORK -->
  <section class="section bg-dark" id="process">
    <div class="hero-glow"></div>
    <div class="wrap">
      <div class="sec-head reveal" style="margin-bottom:0">
        <div class="eyebrow">How We Work</div>
        <h2>Planned with precision. <em>Executed with excellence.</em></h2>
        <p>A transparent process from first call to final walk-through.</p>
      </div>
      <div class="proc-grid">
        <div class="proc-step reveal"><div class="n">01</div><h3>Consultation</h3><p>Understanding your vision, requirements, style preferences, and project goals.</p></div>
        <div class="proc-step reveal"><div class="n">02</div><h3>Site Assessment</h3><p>Detailed inspection and measurement to evaluate surfaces and project requirements.</p></div>
        <div class="proc-step reveal"><div class="n">03</div><h3>Design Selection</h3><p>Curating the ideal textures, finishes, and colour palettes for your space.</p></div>
        <div class="proc-step reveal"><div class="n">04</div><h3>Proposal &amp; Plan</h3><p>Providing a transparent quotation, project timeline, and clear execution plan.</p></div>
      </div>
      <div style="text-align:center;margin-top:2.5rem;position:relative;z-index:2">
        <a href={withBase('/services')} class="btn btn-outline-gold">See Full 8-Step Process</a>
      </div>
    </div>
  </section>

  <!-- (5) PALETTE -->
  <section class="section bg-cream" style="background: #E8E2D5;">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">The Signature Palette</div>
        <h2>Colours curated to live <em>beautifully</em> together.</h2>
        <p>
          The shades that define a Nakkashi finish   from deep estate navies to warm, gilded golds.
        </p>
      </div>
      <div class="palette-img reveal">
        <img src={withBase('/paintpalatte.webp')} alt="The Nakkashi Signature Colour Palette"  loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- SHOWCASE / GALLERY PREVIEW -->
  <section class="section bg-paper" id="showcase">
    <div class="wrap">
      <div class="sec-head reveal">
        <div class="eyebrow">From Our Signature Collection</div>
        <h2>Textures &amp; finishes <em>signed by Nakkashi.</em></h2>
        <p>A closer look at the surface treatments our craftsmen apply on every project   from limewash to metallic accents.</p>
      </div>
      <div class="gallery reveal">
        <div class="gtile g1"><img src={withBase('/Texture 8.webp')} alt="Weather-shield exterior finish sample"  loading="lazy" decoding="async" /><div class="gmeta"><div class="t">Weather-shield Exterior</div><div class="s">Texture · Exterior</div></div></div>
        <div class="gtile g2"><img src={withBase('/Texture 9.webp')} alt="Metallic accent interior finish sample"  loading="lazy" decoding="async" /><div class="gmeta"><div class="t">Metallic Accent</div><div class="s">Texture · Interior</div></div></div>
        <div class="gtile g3"><img src={withBase('/Texture 10.webp')} alt="Royale stucco interior finish sample"  loading="lazy" decoding="async" /><div class="gmeta"><div class="t">Royale Stucco</div><div class="s">Texture · Interior</div></div></div>
        <div class="gtile g4"><img src={withBase('/Texture 11.webp')} alt="Signature feature wall texture sample"  loading="lazy" decoding="async" /><div class="gmeta"><div class="t">Signature Feature Wall</div><div class="s">Texture</div></div></div>
        <div class="gtile g5"><img src={withBase('/Texture 12.webp')} alt="Statement wall finish sample"  loading="lazy" decoding="async" /><div class="gmeta"><div class="t">Statement Finish</div><div class="s">Texture · Commercial</div></div></div>
      </div>
      <p style="text-align:center;margin-top:1.4rem;color:var(--muted);font-size:.88rem;font-style:italic">
        Real project photography currently in production   client site photoshoots underway.
      </p>
      <div style="text-align:center;margin-top:1.2rem">
        <a href={withBase('/gallery')} class="btn btn-ghost">View Full Gallery</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="section bg-cream" id="reviews">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Client Stories</div>
        <h2>Loved by homeowners and designers across the city.</h2>
      </div>
      <div class="testi-grid">
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>The crew was punctual, tidy and genuinely skilled. Our home looks like something out of a magazine   the gold accent wall is everyone's favourite.</p>
          <div class="who">
            <div class="av" data-photo="/testimonials/riya-arora.webp" data-initials="RA">RA</div>
            <div>
              <div class="nm">Riya Arora</div>
              <div class="rl">3 BHK Renovation · Greater Kailash</div>
            </div>
          </div>
        </div>
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>From the colour consultation to the final coat, everything felt premium. No mess, no delays, and the finish is absolutely flawless.</p>
          <div class="who">
            <div class="av" data-photo="/testimonials/vikram-mehta.webp" data-initials="VM">VM</div>
            <div>
              <div class="nm">Vikram Mehta</div>
              <div class="rl">Villa Interiors · Dwarka</div>
            </div>
          </div>
        </div>
        <div class="quote-card reveal">
          <div class="mark">"</div>
          <div class="stars">★★★★★</div>
          <p>We had recurring seepage for years. Nakkashi's waterproofing fixed it completely and the exterior still looks fresh after two monsoons.</p>
          <div class="who">
            <div class="av" data-photo="/testimonials/sunita-kapoor.webp" data-initials="SK">SK</div>
            <div>
              <div class="nm">Sunita Kapoor</div>
              <div class="rl">Exterior &amp; Waterproofing · Rohini</div>
            </div>
          </div>
        </div>
      </div>

      <script is:inline>
        // Progressive-enhance: if a real testimonial photo exists at the data-photo path,
        // swap the avatar for the image. Falls back to initials otherwise (default).
        (function () {
          document.querySelectorAll('.who .av[data-photo]').forEach(function (av) {
            var src = av.getAttribute('data-photo');
            if (!src) return;
            var img = new Image();
            img.onload = function () {
              av.style.backgroundImage = 'url(' + src + ')';
              av.style.backgroundSize = 'cover';
              av.style.backgroundPosition = 'center';
              av.textContent = '';
            };
            img.src = src;
          });
        })();
      </script>
    </div>
  </section>

  <CTABand />

  <script is:inline>
    (function () {
      const swatches = document.querySelectorAll('.swatch');
      swatches.forEach(function (card) {
        card.addEventListener('click', function () {
          var isActive = card.classList.contains('active');
          swatches.forEach(function (c) {
            if (c.classList.contains('active')) {
              c.classList.remove('active');
              c.classList.add('dismiss');
              c.addEventListener('animationend', function () {
                c.classList.remove('dismiss');
              }, { once: true });
            }
          });
          if (!isActive) {
            card.classList.remove('dismiss');
            card.classList.add('active');
          }
        });
      });
    })();
  </script>
</Layout>
