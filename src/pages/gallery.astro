---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CTABand from '../components/CTABand.astro';
import { withBase } from '../lib/url';

const projects = [
  { t: 'Marble Haven Villa',      s: 'Exterior · Venetian Plaster',   cls: 'g1', cat: 'exterior',   img: '/Texture 13.png' },
  { t: 'Gilded Drawing Room',     s: 'Interior · Metallic Accent',     cls: 'g2', cat: 'interior',   img: '/Texture 14.png' },
  { t: 'Royal Master Suite',      s: 'Interior · Royale Stucco',       cls: 'g3', cat: 'interior',   img: '/Texture 15.png' },
  { t: 'Mandakini Feature Wall',  s: 'Texture · Signature Finish',     cls: 'g4', cat: 'texture',    img: '/Texture 16.png' },
  { t: 'Heritage Café Fit-out',   s: 'Commercial · Full Repaint',      cls: 'g5', cat: 'commercial', img: '/Texture 17.png' },
  { t: 'Penthouse Foyer',         s: 'Interior · Raj Hans',            cls: 'g6', cat: 'texture',    img: '/Texture 8.png'  },
  { t: 'Studio Limewash',         s: 'Interior · Azure Limewash',      cls: 'g7', cat: 'interior',   img: '/Texture 9.png'  },
  { t: 'Corporate Lobby',         s: 'Commercial · Statement Wall',    cls: 'g8', cat: 'commercial', img: '/Texture 10.png' },
  { t: 'Ivory Marmorino',         s: 'Exclusive · Signature Finish',   cls: 'ge1', cat: 'exclusive', img: '/Texture 1 EXCL.png'  },
  { t: 'Champagne Royale',        s: 'Exclusive · Premium Interior',   cls: 'ge2', cat: 'exclusive', img: '/Texture 2 EXCl.png'  },
  { t: 'Midnight Plaster',        s: 'Exclusive · Decorative Finish',  cls: 'ge3', cat: 'exclusive', img: '/Texture 3 EXCL.png'  },
  { t: 'Venetian Bronze',         s: 'Exclusive · Luxury Texture',     cls: 'ge4', cat: 'exclusive', img: '/Texture 4 EXCL.png'  },
  { t: 'Pearl Stucco',            s: 'Exclusive · Artisan Craft',      cls: 'ge5', cat: 'exclusive', img: '/Texture 5 EXCL.png'  },
  { t: 'Gilded Damask',           s: 'Exclusive · Statement Wall',     cls: 'ge6', cat: 'exclusive', img: '/Texture 6 EXCL.png'  },
  { t: 'Silver Shimmer',          s: 'Exclusive · Metallic Accent',    cls: 'ge7', cat: 'exclusive', img: '/Texture 7 EXCL.png'  },
  { t: 'Onyx Estate',             s: 'Exclusive · Elite Finish',       cls: 'ge8', cat: 'exclusive', img: '/Texture 8 EXCL.png'  },
];
---
<Layout title="Project Gallery — Nakkashi Signature Painting">
  <PageHero
    eyebrow="Gallery"
    title="Spaces signed by Nakkashi."
    lead="A growing collection of homes, offices, hospitality projects, and statement spaces — each finished with our signature combination of craft, colour, and care."
  />

  <!-- GALLERY -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="sec-head center reveal">
        <div class="eyebrow">Selected Projects</div>
        <h2>A glimpse of <em>recent</em> transformations.</h2>
        <p>From villa exteriors to boutique fit-outs — every project is approached with the same standard of craftsmanship.</p>
      </div>

      <div class="gallery-filters reveal">
        <button class="active" data-filter="all">All</button>
        <button data-filter="interior">Interior</button>
        <button data-filter="exterior">Exterior</button>
        <button data-filter="texture">Texture</button>
        <button data-filter="commercial">Commercial</button>
        <button data-filter="exclusive" class="filter-excl">✦ Exclusive</button>
      </div>

      <div class="gallery reveal" id="gallery">
        {projects.map(p => (
          <div class={`gtile ${p.cls}`} data-cat={p.cat}>
            <img src={withBase(p.img)} alt={p.t} />
            <div class="gmeta">
              <div class="t">{p.t}</div>
              <div class="s">{p.s}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS -->
  <section class="section bg-dark">
    <div class="hero-glow"></div>
    <div class="wrap" style="position:relative;z-index:2">
      <div class="sec-head center reveal">
        <div class="eyebrow">By the Numbers</div>
        <h2>Fifteen years. Twelve hundred <em>spaces.</em></h2>
        <p>A track record built one wall at a time.</p>
      </div>
      <div class="stat-strip">
        <div class="stat-item">
          <div class="num">1,200+</div>
          <div class="lbl">Projects Delivered</div>
        </div>
        <div class="stat-item">
          <div class="num">50+</div>
          <div class="lbl">Master Craftsmen</div>
        </div>
        <div class="stat-item">
          <div class="num">120+</div>
          <div class="lbl">Designer Partners</div>
        </div>
        <div class="stat-item">
          <div class="num">5★</div>
          <div class="lbl">Average Rating</div>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    heading="Want your space <em>here</em>?"
    text="Every project in our gallery began with a free site visit. Yours could too. Tell us about your space and we'll plan the next step together."
    primaryLabel="Start Your Project"
    primaryHref="/quote"
    secondaryLabel="Talk to a Designer"
    secondaryHref="/contact"
  />

  <style>
    .gtile { padding: 1rem 1.1rem; }
    .gtile .gmeta { max-width: 100%; overflow: hidden; }
    .gtile .gmeta .t {
      font-size: clamp(.82rem, 1.4vw, 1.1rem);
      line-height: 1.25;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }
    .gtile .gmeta .s {
      font-size: .65rem;
      letter-spacing: .08em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      margin-top: .2rem;
    }
    @media (max-width: 760px) {
      .gtile { padding: .7rem .85rem; }
      .gtile .gmeta .t { font-size: .78rem; }
      .gtile .gmeta .s { font-size: .6rem; letter-spacing: .06em; }
    }
  </style>

  <script is:inline>
    (function () {
      const buttons = document.querySelectorAll('.gallery-filters button');
      const tiles = document.querySelectorAll('#gallery .gtile');
      buttons.forEach(b => {
        b.addEventListener('click', () => {
          buttons.forEach(x => x.classList.remove('active'));
          b.classList.add('active');
          const f = b.dataset.filter;
          tiles.forEach(t => {
            t.style.display = (f === 'all' || t.dataset.cat === f) ? '' : 'none';
          });
        });
      });
    })();
  </script>
</Layout>
