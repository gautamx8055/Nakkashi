---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { withBase } from '../lib/url';
---
<Layout title="Contact Nakkashi — Talk to Our Project Team">
  <PageHero
    eyebrow="Contact"
    title="We'd love to hear about your space."
    lead="Whether you're ready to start, exploring ideas, or just want to chat finishes — our team is here. Reach us by phone, email, or the form below."
  />

  <!-- CONTACT GRID -->
  <section class="section bg-paper">
    <div class="wrap">
      <div class="form-wrap">
        <div class="form-card reveal">
          <h3>Send Us a Message</h3>
          <form id="contactForm" name="contact" method="POST" action="https://formspree.io/f/mdarwygd">
            <input type="hidden" name="_subject" value="New Contact Message — Nakkashi" />
            <div class="form-grid">
              <div class="field">
                <label for="name">Name *</label>
                <input id="name" name="name" type="text" required placeholder="Your name" />
              </div>
              <div class="field">
                <label for="phone">Phone *</label>
                <input id="phone" name="phone" type="tel" required placeholder="+91 98765 43210" />
              </div>
              <div class="field full">
                <label for="email">Email *</label>
                <input id="email" name="email" type="email" required placeholder="you@example.com" />
              </div>
              <div class="field full">
                <label for="topic">What's this about?</label>
                <select id="topic" name="topic">
                  <option value="">Select…</option>
                  <option>General enquiry</option>
                  <option>Project quotation</option>
                  <option>Designer / architect partnership</option>
                  <option>Career enquiry</option>
                  <option>Press / media</option>
                </select>
              </div>
              <div class="field full">
                <label for="message">Your message *</label>
                <textarea id="message" name="message" required placeholder="Tell us how we can help."></textarea>
              </div>
              <div class="field full">
                <button type="submit" id="contactBtn" class="btn btn-gold" style="width:100%;justify-content:center;padding:1rem;font-size:1rem">
                  Send Message
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7" />
                  </svg>
                </button>
              </div>
            </div>
            <div id="contactSuccess" style="display:none;text-align:center;padding:2rem 1rem">
              <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold-deep));color:#fff;display:grid;place-items:center;margin:0 auto 1rem;box-shadow:0 12px 30px rgba(224,170,62,.4)">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12l5 5L20 7"/></svg>
              </div>
              <h4 style="font-family:var(--display);font-size:1.5rem;color:var(--navy-deep);margin:0 0 .5rem">Message sent!</h4>
              <p style="color:var(--muted)">Our team will reach out within 24 hours.</p>
            </div>
          </form>
          <script is:inline>
            document.getElementById('contactForm').addEventListener('submit', async function(e) {
              e.preventDefault();
              const btn = document.getElementById('contactBtn');
              btn.textContent = 'Sending…';
              btn.disabled = true;
              try {
                const res = await fetch(this.action, {
                  method: 'POST', body: new FormData(this),
                  headers: { 'Accept': 'application/json' }
                });
                if (res.ok) {
                  this.querySelector('.form-grid').style.display = 'none';
                  document.getElementById('contactSuccess').style.display = 'block';
                } else { throw new Error(); }
              } catch {
                btn.textContent = 'Send Message';
                btn.disabled = false;
                alert('Something went wrong. Please try again or email us directly.');
              }
            });
          </script>
        </div>

        <aside class="form-aside">
          <div class="aside-card reveal" style="background:linear-gradient(160deg,var(--navy),var(--navy-deep));color:var(--cream);border:none">
            <h4 style="color:#fff">Get in touch</h4>
            <div class="row" style="color:rgba(247,243,234,.9)">
              <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.36 1.9.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0122 16.92z"/></svg>
              <span><strong>+91 74006 40093</strong><br /><span style="opacity:.7;font-size:.88rem">Mon – Sat · 9am – 7pm</span></span>
            </div>
            <div class="row" style="color:rgba(247,243,234,.9)">
              <svg viewBox="0 0 24 24"><path d="M4 4h16v16H4z"/><path d="m22 6-10 7L2 6"/></svg>
              <span><strong>nakkashipainting@gmail.com</strong><br /><span style="opacity:.7;font-size:.88rem">Replies within 24 hours</span></span>
            </div>
            <div class="row" style="color:rgba(247,243,234,.9)">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span><strong>Connaught Place, New Delhi</strong><br /><span style="opacity:.7;font-size:.88rem">Studio open Mon – Sat, 9am – 7pm</span></span>
            </div>
          </div>

          <div class="aside-card reveal">
            <h4>Ready to begin?</h4>
            <p style="margin-bottom:1rem">Skip the back-and-forth and request a quotation directly. We'll respond within 24 hours.</p>
            <a href={withBase('/quote')} class="btn btn-dark" style="font-size:.9rem;padding:.75rem 1.3rem">Request a Quote →</a>
          </div>

          <div class="aside-card reveal">
            <h4>Follow our work</h4>
            <p>See our latest projects and texture inspiration on social.</p>
            <div class="foot-soc" style="margin-top:1rem">
              <a href="#" aria-label="Instagram" style="border-color:var(--line)">
                <svg viewBox="0 0 24 24" style="stroke:var(--navy-deep)">
                  <rect x="2" y="2" width="20" height="20" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
              </a>
              <a href="#" aria-label="Facebook" style="border-color:var(--line)">
                <svg viewBox="0 0 24 24" style="stroke:var(--navy-deep)">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
                </svg>
              </a>
              <a href="#" aria-label="WhatsApp" style="border-color:var(--line)">
                <svg viewBox="0 0 24 24" style="stroke:var(--navy-deep)">
                  <path d="M21 11.5a8.38 8.38 0 01-9 8.5 8.5 8.5 0 01-3.9-.9L3 21l1.9-5A8.5 8.5 0 1121 11.5z" />
                </svg>
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>
