---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  preloadHero?: boolean;
}

const {
  title,
  description = 'Nakkashi — Premium painting and decorative finishes. Signature textures, master craftsmanship, and professional execution for residential, commercial, and hospitality spaces.',
  preloadHero = false,
} = Astro.props;
import { withBase } from '../lib/url';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="alternate icon" href={withBase('/favicon.ico')} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#022044" />
    <link rel="canonical" href={`https://nakkashipainting.com${Astro.url.pathname}`} />
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://nakkashipainting.com${Astro.url.pathname}`} />
    <meta property="og:site_name" content="Nakkashi Signature Painting" />
    <title>{title}</title>
    <!-- Preload hero image on the homepage for LCP -->
    {preloadHero && (
      <link
        rel="preload"
        as="image"
        href={withBase('/hero section.webp')}
        fetchpriority="high"
        type="image/webp"
      />
    )}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-blocking Google Fonts (swap uses fallback fonts until Google's are loaded) -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..500&family=Outfit:wght@400;500;600;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..500&family=Outfit:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <TopBar />
    <div class="offer-strip" role="banner">
      <span class="offer-text"><strong>Late? It's Free.</strong> — India-first written on-time delivery guarantee</span>
      <span class="offer-text-mobile"><strong>Late? It's Free.</strong> — On-time or your next room is free</span>
      <a href={withBase('/quote')} class="offer-cta">Book a Site Visit →</a>
    </div>
    <Header />
    <main>
      <slot />
    </main>

    <!-- Floating WhatsApp button -->
    <a
      href="https://wa.me/917400640093?text=Hi%20Nakkashi%2C%20I%27d%20like%20to%20know%20more%20about%20your%20services."
      class="wa-float"
      target="_blank"
      rel="noopener"
      aria-label="Chat with Nakkashi on WhatsApp"
    >
      <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <path
          fill="currentColor"
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M27.146 4.784A15.86 15.86 0 0 0 15.995.166C7.19.166.02 7.335.017 16.144a15.94 15.94 0 0 0 2.131 7.977L.02 31.834l7.888-2.069a15.94 15.94 0 0 0 7.62 1.942h.006c8.804 0 15.973-7.169 15.976-15.978a15.87 15.87 0 0 0-4.664-11.291zM15.994 29.11h-.005a13.26 13.26 0 0 1-6.759-1.851l-.485-.288-5.03 1.319 1.342-4.905-.316-.503a13.24 13.24 0 0 1-2.028-7.07c.003-7.322 5.961-13.28 13.286-13.28 3.548 0 6.883 1.383 9.39 3.893a13.19 13.19 0 0 1 3.886 9.397c-.003 7.323-5.961 13.288-13.28 13.288zm7.283-9.947c-.399-.2-2.361-1.166-2.727-1.299-.365-.133-.632-.199-.898.2-.266.399-1.031 1.299-1.264 1.565-.233.267-.466.3-.865.1-.399-.2-1.685-.621-3.211-1.982-1.186-1.058-1.987-2.365-2.22-2.764-.233-.399-.025-.615.175-.814.179-.179.399-.466.599-.699.199-.234.266-.4.4-.666.132-.266.066-.499-.033-.699-.1-.2-.898-2.164-1.231-2.963-.323-.777-.652-.672-.898-.684-.232-.011-.499-.014-.765-.014a1.47 1.47 0 0 0-1.064.499c-.365.399-1.398 1.365-1.398 3.329s1.431 3.862 1.63 4.128c.199.266 2.815 4.301 6.822 6.031.953.411 1.696.657 2.276.841.956.304 1.827.261 2.514.158.767-.114 2.361-.965 2.694-1.898.332-.932.332-1.731.232-1.898-.099-.166-.365-.266-.764-.466z"
        />
      </svg>
    </a>

    <Footer />

    <style>
      .wa-float {
        position: fixed;
        left: 1.2rem;
        bottom: 1.4rem;
        z-index: 1050;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        background: #25D366;
        color: #fff;
        display: grid;
        place-items: center;
        box-shadow: 0 8px 20px rgba(37, 211, 102, .35), 0 2px 6px rgba(0, 0, 0, .18);
        text-decoration: none;
        transition: transform .2s, box-shadow .2s;
        animation: waFloatPulse 2.8s ease-in-out infinite;
      }
      .wa-float:hover {
        transform: translateY(-2px) scale(1.05);
        box-shadow: 0 12px 26px rgba(37, 211, 102, .5), 0 3px 8px rgba(0, 0, 0, .2);
      }
      .wa-float svg { display: block; }
      @keyframes waFloatPulse {
        0%, 100% { box-shadow: 0 8px 20px rgba(37, 211, 102, .35), 0 2px 6px rgba(0, 0, 0, .18), 0 0 0 0 rgba(37, 211, 102, 0); }
        50%      { box-shadow: 0 8px 20px rgba(37, 211, 102, .35), 0 2px 6px rgba(0, 0, 0, .18), 0 0 0 10px rgba(37, 211, 102, 0); }
      }
      @media (max-width: 520px) {
        .wa-float { left: .9rem; bottom: 1rem; width: 52px; height: 52px; }
        .wa-float svg { width: 26px; height: 26px; }
      }
    </style>

    <script is:inline>
      (function () {
        const io = new IntersectionObserver(
          (entries) =>
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }),
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal').forEach((el, i) => {
          el.style.transitionDelay = (i % 3) * 0.08 + 's';
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
