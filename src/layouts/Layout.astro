---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Nakkashi — Premium painting and decorative finishes. Signature textures, master craftsmanship, and professional execution for residential, commercial, and hospitality spaces.',
} = Astro.props;
import { withBase } from '../lib/url';
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href={withBase('/Nakashi-logo-final-Transparent.png')} />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,400..600&family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <TopBar />
    <div class="offer-strip" role="banner">
      <span class="offer-text">Get <strong>25% OFF</strong> on your Signature Wall — Exclusive Nakkashi offer</span>
      <a href={withBase('/quote')} class="offer-cta">Book Now →</a>
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        const io = new IntersectionObserver(
          (entries) =>
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }),
          { threshold: 0.12 }
        );
        document.querySelectorAll('.reveal').forEach((el, i) => {
          el.style.transitionDelay = (i % 3) * 0.08 + 's';
          io.observe(el);
        });
      })();
    </script>
  </body>
</html>
